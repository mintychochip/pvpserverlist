---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSelector from './LanguageSelector.astro';
import { getStoredLocale, t } from '../lib/i18n';

const currentLocale = getStoredLocale();

// Main nav - core actions only
const mainNavItems = [
  { label: t('nav.minecraft', currentLocale), href: '/minecraft' },
  { label: t('nav.wizard', currentLocale), href: '/wizard', icon: '🔮' },
  { label: t('nav.discover', currentLocale), href: '/discover' },
  { label: t('nav.premium', currentLocale), href: '/premium', icon: '⭐' },
];

// Secondary nav items (dropdown or condensed)
const moreNavItems = [
  { label: t('nav.uptime', currentLocale), href: '/uptime', icon: '⏱️' },
  { label: t('nav.events', currentLocale), href: '/events', icon: '📅' },
  { label: t('nav.bannerMaker', currentLocale), href: '/banner-maker', icon: '🎨' },
  { label: t('nav.categories', currentLocale), href: '/minecraft#categories' },
  { label: t('nav.compare', currentLocale), href: '/compare', icon: '📊' },
];

// User-related items
const userNavItems = [
  { label: t('nav.favorites', currentLocale), href: '/favorites', icon: '♡' },
  { label: t('nav.dashboard', currentLocale), href: '/dashboard', icon: '📊' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b border-[var(--border-color)] transition-colors duration-300 bg-[var(--bg-primary)]/90">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <svg class="h-8 w-auto" viewBox="0 0 200 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Icon -->
          <g transform="translate(0, 4)">
            <circle cx="8" cy="8" r="4" fill="#00d9ff"/>
            <circle cx="24" cy="4" r="4" fill="#00d9ff"/>
            <circle cx="24" cy="20" r="4" fill="#00d9ff"/>
            <circle cx="8" cy="16" r="4" fill="#00d9ff"/>
            <circle cx="16" cy="12" r="5" fill="#ff006e"/>
            <path d="M8 8L16 12M24 4L16 12M24 20L16 12M8 16L16 12" 
                  stroke="#00d9ff" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
          </g>
          <text x="40" y="28" font-family="Space Grotesk, Inter, sans-serif" font-size="22" 
                font-weight="700" fill="currentColor" letter-spacing="-0.5">GuildPost</text>
        </svg>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {mainNavItems.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-tertiary)] transition-all duration-200 font-medium text-sm"
          >
            {item.icon && <span class="mr-1">{item.icon}</span>}
            {item.label}
          </a>
        ))}
        
        <!-- More dropdown -->
        <div class="relative group">
          <button class="px-3 py-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-tertiary)] transition-all duration-200 font-medium text-sm flex items-center gap-1">
            {t('common.more', currentLocale)}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-48 bg-[var(--bg-secondary)] border border-[var(--border-color)] rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {moreNavItems.map((item) => (
              <a
                href={item.href}
                class="block px-4 py-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-tertiary)] transition-colors text-sm first:rounded-t-lg last:rounded-b-lg"
              >
                {item.icon && <span class="mr-2">{item.icon}</span>}
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </nav>

      <!-- Right side: User actions -->
      <div class="flex items-center gap-2">
        <!-- Language Selector -->
        <LanguageSelector currentLocale={currentLocale} />
        
        <!-- Theme Toggle -->
        <ThemeToggle />
        
        <!-- User nav (hidden on mobile) -->
        <nav class="hidden md:flex items-center gap-1">
          {userNavItems.map((item) => (
            <a
              href={item.href}
              class="p-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-tertiary)] transition-all duration-200"
              title={item.label}
            >
              <span>{item.icon}</span>
            </a>
          ))}
        </nav>
        
        <!-- Add Server CTA -->
        <a
          href="/submit"
          class="hidden sm:inline-flex items-center gap-1 px-3 py-2 font-medium rounded-lg transition-all duration-200 text-sm bg-[var(--accent-primary)] text-[var(--bg-primary)] hover:opacity-90"
        >
          <span>+</span>
          <span class="hidden sm:inline">{t('nav.addServer', currentLocale)}</span>
        </a>
        
        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-tertiary)] transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden lg:hidden py-4 border-t border-[var(--border-color)] transition-colors">
      <nav class="flex flex-col gap-1">
        {[...mainNavItems, ...moreNavItems, ...userNavItems].map((item) => (
          <a 
            href={item.href}
            class="px-3 py-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-tertiary)] transition-colors font-medium"
          >
            {item.icon && <span class="mr-2">{item.icon}</span>}
            {item.label}
          </a>
        ))}
        <a 
          href="/submit" 
          class="mt-2 px-3 py-2 rounded-lg bg-[var(--accent-primary)] text-[var(--bg-primary)] font-medium text-center"
        >
          + Add Your Server
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>