---
// SmartIntentSearch - Phase-based intent wizard (no chatbot feel)

export interface Props {
  id?: string;
}

const { id = 'smart-search' } = Astro.props;
---

<div id={id} class="smart-intent-wizard">
  <!-- Search Bar -->
  <div class="search-bar-container" id={`${id}-search-bar`}>
    <div class="input-wrapper">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
      </svg>
      <input 
        type="text" 
        id={`${id}-input`}
        placeholder="Describe your ideal server..."
        class="search-input"
        autocomplete="off"
      />
      <button id={`${id}-btn`} class="search-button">Find</button>
    </div>
    
    <div class="suggestions">
      <span class="suggestion-label">Try:</span>
      <button class="suggestion-chip" data-query="survival smp with claims">survival smp</button>
      <button class="suggestion-chip" data-query="pvp factions">pvp factions</button>
      <button class="suggestion-chip" data-query="skyblock economy">skyblock</button>
      <button class="suggestion-chip" data-query="small community">small community</button>
    </div>
  </div>

  <!-- Wizard Modal (hidden initially) -->
  <div id={`${id}-wizard`} class="wizard-overlay hidden">
    <div class="wizard-container">
      <!-- Progress -->
      <div class="wizard-progress">
        <div class="progress-bar">
          <div class="progress-fill" id={`${id}-progress`}></div>
        </div>
        <span class="progress-text" id={`${id}-progress-text`}>Step 1 of 2</span>
      </div>

      <!-- Step 1: Game Selection -->
      <div class="wizard-step active" data-step="1">
        <h3>What game are you looking for?</h3>
        <p class="step-desc">Select your game</p>
        <div class="option-grid">
          <button class="option-card large" data-value="minecraft" data-type="game">
            <span class="option-icon">🎮</span>
            <span class="option-label">Minecraft</span>
            <span class="option-badge">Live</span>
          </button>
          <button class="option-card large disabled" data-value="rust" data-type="game" disabled>
            <span class="option-icon">🔧</span>
            <span class="option-label">Rust</span>
            <span class="option-badge soon">Soon</span>
          </button>
          <button class="option-card large disabled" data-value="cs2" data-type="game" disabled>
            <span class="option-icon">🔫</span>
            <span class="option-label">CS2</span>
            <span class="option-badge soon">Soon</span>
          </button>
          <button class="option-card large" data-value="other" data-type="game">
            <span class="option-icon">✏️</span>
            <span class="option-label">Other...</span>
            <span class="option-desc">Type below</span>
          </button>
        </div>
        <div class="other-input hidden" id={`${id}-game-other`}>
          <input type="text" placeholder="What game?" />
          <button class="confirm-btn">Continue</button>
        </div>
      </div>

      <!-- Step 2: Gamemode -->
      <div class="wizard-step" data-step="2">
        <button class="back-btn" data-back="1">← Back</button>
        <h3>What gamemode?</h3>
        <p class="step-desc">Choose your experience</p>
        <div class="option-grid">
          <button class="option-card" data-value="survival" data-type="gamemode">
            <span class="option-icon">🛡️</span>
            <span class="option-label">Survival</span>
          </button>
          <button class="option-card" data-value="pvp" data-type="gamemode">
            <span class="option-icon">⚔️</span>
            <span class="option-label">PvP</span>
          </button>
          <button class="option-card" data-value="skyblock" data-type="gamemode">
            <span class="option-icon">🏝️</span>
            <span class="option-label">Skyblock</span>
          </button>
          <button class="option-card" data-value="creative" data-type="gamemode">
            <span class="option-icon">🎨</span>
            <span class="option-label">Creative</span>
          </button>
          <button class="option-card" data-value="minigames" data-type="gamemode">
            <span class="option-icon">🎲</span>
            <span class="option-label">Minigames</span>
          </button>
          <button class="option-card" data-value="hardcore" data-type="gamemode">
            <span class="option-icon">🔥</span>
            <span class="option-label">Hardcore</span>
          </button>
          <button class="option-card" data-value="smp" data-type="gamemode">
            <span class="option-icon">🤝</span>
            <span class="option-label">SMP</span>
          </button>
          <button class="option-card" data-value="factions" data-type="gamemode">
            <span class="option-icon">🏰</span>
            <span class="option-label">Factions</span>
          </button>
          <button class="option-card" data-value="prison" data-type="gamemode">
            <span class="option-icon">⛓️</span>
            <span class="option-label">Prison</span>
          </button>
          <button class="option-card" data-value="modded" data-type="gamemode">
            <span class="option-icon">⚙️</span>
            <span class="option-label">Modded</span>
          </button>
          <button class="option-card" data-value="rp" data-type="gamemode">
            <span class="option-icon">🎭</span>
            <span class="option-label">Roleplay</span>
          </button>
          <button class="option-card other" data-value="other" data-type="gamemode">
            <span class="option-icon">✏️</span>
            <span class="option-label">Other...</span>
          </button>
        </div>
        <div class="other-input hidden" id={`${id}-mode-other`}>
          <input type="text" placeholder="Describe the gamemode..." />
          <button class="confirm-btn">Continue</button>
        </div>
        <button class="skip-btn" data-skip="search">Skip → Search with what I have</button>
      </div>

      <!-- Searching State -->
      <div class="wizard-step" data-step="searching">
        <div class="searching-state">
          <div class="spinner"></div>
          <p>Finding servers...</p>
          <p class="search-query" id={`${id}-searching-query`}></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div id={`${id}-results`} class="results-container"></div>
  
  <!-- Refinements (after results) -->
  <div id={`${id}-refinements`} class="refinements-container hidden">
    <div class="refinements-header">
      <h4>🔍 Refine Results</h4>
      <button id={`${id}-clear-refinements`}>Clear all</button>
    </div>
    
    <div class="refinement-section">
      <span class="refinement-label">Features:</span>
      <div class="refinement-chips" data-refine="features">
        <button class="refine-chip" data-value="economy">💰 Economy</button>
        <button class="refine-chip" data-value="claims">🏠 Claims</button>
        <button class="refine-chip" data-value="community">👥 Discord</button>
        <button class="refine-chip" data-value="anticheat">🔒 Anti-Cheat</button>
        <button class="refine-chip" data-value="mmo">🏛️ McMMO</button>
        <button class="refine-chip" data-value="events">🌍 Events</button>
        <button class="refine-chip" data-value="bedrock">📱 Bedrock</button>
        <button class="refine-chip" data-value="voice">🎤 Voice</button>
        <button class="refine-chip" data-value="custom">🧙 Custom</button>
        <button class="refine-chip" data-value="shops">🏪 Shops</button>
        <button class="refine-chip" data-value="towny">🏘️ Towny</button>
        <button class="refine-chip" data-value="quests">📜 Quests</button>
        <button class="refine-chip" data-value="crates">🎁 Crates</button>
        <button class="refine-chip" data-value="kits">🎒 Kits</button>
        <button class="refine-chip" data-value="parkour">🏃 Parkour</button>
        <button class="refine-chip" data-value="vanilla">🌿 Vanilla</button>
      </div>
    </div>
    
    <div class="refinement-section">
      <span class="refinement-label">Size:</span>
      <div class="refinement-chips" data-refine="size">
        <button class="refine-chip" data-value="small">🌱 Small</button>
        <button class="refine-chip" data-value="medium">🌳 Medium</button>
        <button class="refine-chip" data-value="large">🌲 Large</button>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ wizardId: id }}>
  // Wait for DOM to be ready
  function initWizard() {
  const id = wizardId;
  const container = document.getElementById(id);
  if (!container) {
    console.error('SmartIntentSearch: Container not found for id:', id);
    return;
  }

  const searchBar = document.getElementById(`${id}-search-bar`);
  const wizard = document.getElementById(`${id}-wizard`);
  const input = document.getElementById(`${id}-input`);
  const btn = document.getElementById(`${id}-btn`);
  const results = document.getElementById(`${id}-results`);
  const refinements = document.getElementById(`${id}-refinements`);
  const progressFill = document.getElementById(`${id}-progress`);
  const progressText = document.getElementById(`${id}-progress-text`);
  const searchingQuery = document.getElementById(`${id}-searching-query`);

  if (!wizard) {
    console.error('SmartIntentSearch: Wizard element not found');
    return;
  }

  let intent = { game: null, gamemode: null, features: [], size: null, originalQuery: '' };
  let currentStep = 1;

  // Keyword databases
  const GAME_KEYWORDS = { minecraft: ['minecraft', 'mc'], rust: ['rust'], cs2: ['cs2', 'csgo'] };
  const MODE_KEYWORDS = {
    survival: ['survival', 'smp'], pvp: ['pvp', 'factions'], skyblock: ['skyblock'],
    creative: ['creative', 'build'], minigames: ['minigame', 'bedwars'], hardcore: ['hardcore'],
    prison: ['prison'], modded: ['modded', 'forge', 'fabric'], smp: ['smp'], rp: ['roleplay', 'rp']
  };

  // Parse intent from initial query
  function parseIntent(text) {
    const lower = text.toLowerCase();
    const result = { game: null, gamemode: null, features: [], size: null };
    
    for (const [game, keywords] of Object.entries(GAME_KEYWORDS)) {
      if (keywords.some(k => lower.includes(k))) { result.game = game; break; }
    }
    for (const [mode, keywords] of Object.entries(MODE_KEYWORDS)) {
      if (keywords.some(k => lower.includes(k))) { result.gamemode = mode; break; }
    }
    if (/\b(small|tiny)\b/.test(lower)) result.size = 'small';
    else if (/\b(medium|mid)\b/.test(lower)) result.size = 'medium';
    else if (/\b(large|big|huge)\b/.test(lower)) result.size = 'large';
    
    return result;
  }

  function showStep(n) {
    if (!wizard) return;
    wizard.querySelectorAll('.wizard-step').forEach(s => s.classList.remove('active'));
    if (n === 'searching') {
      wizard.querySelector('[data-step="searching"]')?.classList.add('active');
      if (progressFill) progressFill.style.width = '100%';
      if (progressText) progressText.textContent = 'Searching...';
    } else {
      wizard.querySelector(`[data-step="${n}"]`)?.classList.add('active');
      if (progressFill) progressFill.style.width = `${(n / 2) * 100}%`;
      if (progressText) progressText.textContent = `Step ${n} of 2`;
    }
    currentStep = n;
  }

  function openWizard() {
    if (!wizard || !searchBar) {
      console.error('SmartIntentSearch: Cannot open wizard - elements not found', { wizard: !!wizard, searchBar: !!searchBar });
      return;
    }
    wizard.classList.remove('hidden');
    searchBar.classList.add('hidden');
    
    // Determine starting step based on parsed intent
    if (!intent.game) {
      showStep(1);
    } else if (!intent.gamemode) {
      showStep(2);
    } else {
      doSearch();
    }
  }

  function closeWizard() {
    if (wizard) wizard.classList.add('hidden');
    if (searchBar) searchBar.classList.remove('hidden');
  }

  function buildQuery() {
    const parts = [];
    if (intent.game) parts.push(intent.game);
    if (intent.gamemode) parts.push(intent.gamemode);
    parts.push(...intent.features);
    if (intent.size) parts.push(intent.size);
    return parts.join(' ') || intent.originalQuery || 'minecraft';
  }

  async function doSearch() {
    showStep('searching');
    if (searchingQuery) searchingQuery.textContent = buildQuery();
    
    if (results) {
      results.innerHTML = '<div class="loading-state"><div class="spinner"></div><p>Searching...</p></div>';
      results.classList.remove('hidden');
    }
    
    try {
      const res = await fetch('/api/search/semantic', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: buildQuery(), limit: 12 })
      });
      const data = await res.json();
      
      closeWizard();
      
      if (data.results?.length && results) {
        results.innerHTML = `
          <div class="results-header"><h3>Found ${data.results.length} servers</h3></div>
          <div class="results-grid">
            ${data.results.map(s => `
              <a href="/servers/${s.id}" class="server-card">
                <div class="server-header">
                  <div class="server-icon">${s.icon ? `<img src="${s.icon}" alt="" />` : '⛏️'}</div>
                  <div class="server-info">
                    <h4>${s.name}</h4>
                    <p>${s.ip}:${s.port}</p>
                  </div>
                </div>
                <div class="server-meta">
                  <span class="status ${s.status || 'offline'}">${s.status === 'online' ? '●' : '○'} ${s.players_online || 0}/${s.max_players || '?'}</span>
                  <span class="votes">▲ ${s.vote_count || 0}</span>
                </div>
              </a>
            `).join('')}
          </div>
        `;
        refinements?.classList.remove('hidden');
        updateRefinementUI();
      } else if (results) {
        results.innerHTML = '<div class="empty-state"><p>No servers found. Try different terms.</p></div>';
      }
    } catch (e) {
      if (results) results.innerHTML = '<div class="empty-state"><p>Search failed. Please try again.</p></div>';
    }
  }

  function updateRefinementUI() {
    if (!container) return;
    container.querySelectorAll('.refine-chip').forEach(chip => {
      const type = chip.closest('.refinement-chips')?.dataset.refine;
      const value = chip.dataset.value;
      chip.classList.remove('active');
      if (type === 'features' && intent.features.includes(value)) chip.classList.add('active');
      if (type === 'size' && intent.size === value) chip.classList.add('active');
    });
  }

  // Event handlers
  if (btn && input) {
    btn.addEventListener('click', () => {
      intent.originalQuery = input.value.trim();
      intent = { ...intent, ...parseIntent(intent.originalQuery) };
      openWizard();
    });

    input.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        intent.originalQuery = input.value.trim();
        intent = { ...intent, ...parseIntent(intent.originalQuery) };
        openWizard();
      }
    });
  }

  // Suggestion chips
  if (input) {
    container.querySelectorAll('.suggestion-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        input.value = chip.dataset.query;
        intent.originalQuery = chip.dataset.query;
        intent = { ...intent, ...parseIntent(intent.originalQuery) };
        openWizard();
      });
    });
  }

  // Step 1: Game selection
  wizard.querySelectorAll?.('[data-step="1"] .option-card:not(.disabled)').forEach(card => {
    card.addEventListener('click', () => {
      const value = card.dataset.value;
      if (value === 'other') {
        document.getElementById(`${id}-game-other`)?.classList.remove('hidden');
      } else {
        intent.game = value;
        showStep(2);
      }
    });
  });

  document.getElementById(`${id}-game-other`)?.querySelector('.confirm-btn')?.addEventListener('click', function() {
    const val = this.previousElementSibling.value.trim();
    if (val) {
      intent.game = val;
      showStep(2);
    }
  });

  // Step 2: Gamemode
  wizard.querySelectorAll?.('[data-step="2"] .option-card:not(.other)').forEach(card => {
    card.addEventListener('click', () => {
      intent.gamemode = card.dataset.value;
      doSearch();
    });
  });

  wizard.querySelector?.('[data-step="2"] .option-card.other')?.addEventListener('click', () => {
    document.getElementById(`${id}-mode-other`)?.classList.remove('hidden');
  });

  document.getElementById(`${id}-mode-other`)?.querySelector('.confirm-btn')?.addEventListener('click', function() {
    const val = this.previousElementSibling.value.trim();
    if (val) {
      intent.gamemode = val;
      doSearch();
    }
  });

  // Back button
  wizard.querySelector?.('.back-btn')?.addEventListener('click', () => showStep(1));

  // Skip button
  wizard.querySelector?.('.skip-btn')?.addEventListener('click', () => doSearch());

  // Refinement chips
  container.querySelectorAll('.refine-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const type = chip.closest('.refinement-chips')?.dataset.refine;
      const value = chip.dataset.value;
      
      if (type === 'features') {
        if (intent.features.includes(value)) {
          intent.features = intent.features.filter(f => f !== value);
        } else {
          intent.features.push(value);
        }
      } else if (type === 'size') {
        intent.size = intent.size === value ? null : value;
      }
      
      updateRefinementUI();
      doSearch();
    });
  });

  // Clear refinements
  document.getElementById(`${id}-clear-refinements`)?.addEventListener('click', () => {
    intent.features = [];
    intent.size = null;
    updateRefinementUI();
    doSearch();
  });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWizard);
  } else {
    initWizard();
  }
</script>

<style>
  .smart-intent-wizard {
    width: 100%;
  }

  .search-bar-container {
    margin-bottom: 1rem;
  }

  .input-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: #1a1a25;
    border: 1px solid #2a2a3a;
    border-radius: 12px;
  }

  .search-icon {
    color: #8892b0;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: #fff;
    font-size: 1rem;
    outline: none;
  }

  .search-input::placeholder {
    color: #8892b0;
  }

  .search-button {
    padding: 0.5rem 1rem;
    background: #00f5d4;
    color: #0a0a0f;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
  }

  .search-button:hover {
    background: #00d4b8;
  }

  .suggestions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .suggestion-chip {
    padding: 0.25rem 0.75rem;
    background: #1a1a25;
    border: 1px solid #2a2a3a;
    border-radius: 20px;
    color: #8892b0;
    font-size: 0.875rem;
    cursor: pointer;
  }

  .suggestion-chip:hover {
    background: #2a2a3a;
    color: #fff;
  }

  /* Wizard Overlay */
  .wizard-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 15, 0.95);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .wizard-overlay.hidden {
    display: none;
  }

  .wizard-container {
    background: #12121a;
    border: 1px solid #2a2a3a;
    border-radius: 16px;
    padding: 2rem;
    max-width: 700px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
  }

  /* Progress */
  .wizard-progress {
    margin-bottom: 1.5rem;
  }

  .progress-bar {
    height: 4px;
    background: #2a2a3a;
    border-radius: 2px;
    margin-bottom: 0.5rem;
  }

  .progress-fill {
    height: 100%;
    background: #00f5d4;
    border-radius: 2px;
    transition: width 0.3s;
  }

  .progress-text {
    font-size: 0.875rem;
    color: #8892b0;
  }

  /* Steps */
  .wizard-step {
    display: none;
  }

  .wizard-step.active {
    display: block;
    animation: fadeIn 0.3s;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .wizard-step h3 {
    color: #fff;
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .step-desc {
    color: #8892b0;
    margin-bottom: 1.5rem;
  }

  .back-btn {
    background: transparent;
    border: none;
    color: #8892b0;
    cursor: pointer;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    padding: 0;
  }

  .back-btn:hover {
    color: #fff;
  }

  /* Option Grid */
  .option-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .option-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .option-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem;
    background: #1a1a25;
    border: 1px solid #2a2a3a;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .option-card:hover:not(.disabled) {
    border-color: #00f5d4;
    transform: translateY(-2px);
  }

  .option-card.large {
    padding: 1.5rem;
  }

  .option-card.disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .option-icon {
    font-size: 1.5rem;
  }

  .option-card.large .option-icon {
    font-size: 2rem;
  }

  .option-label {
    color: #fff;
    font-weight: 500;
  }

  .option-badge {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    background: #00f5d4;
    color: #0a0a0f;
    border-radius: 4px;
  }

  .option-badge.soon {
    background: #2a2a3a;
    color: #8892b0;
  }

  .option-desc {
    font-size: 0.75rem;
    color: #8892b0;
  }

  .option-card.other {
    border-style: dashed;
    color: #8892b0;
  }

  /* Other input */
  .other-input {
    margin-top: 1rem;
    display: flex;
    gap: 0.5rem;
  }

  .other-input.hidden {
    display: none;
  }

  .other-input input {
    flex: 1;
    padding: 0.75rem;
    background: #0a0a0f;
    border: 1px solid #2a2a3a;
    border-radius: 8px;
    color: #fff;
    outline: none;
  }

  .other-input input:focus {
    border-color: #00f5d4;
  }

  .confirm-btn {
    padding: 0.75rem 1rem;
    background: #00f5d4;
    color: #0a0a0f;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
