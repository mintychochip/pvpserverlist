---
// Related Servers Component - Internal Linking for SEO
// Displays related servers based on tags for better internal linking

interface Props {
  currentServerId: string;
  tags: string[];
  servers: Array<{
    id: string;
    name: string;
    ip: string;
    port: number;
    icon?: string;
    tags?: string[];
    players_online?: number;
    max_players?: number;
    status?: string;
    vote_count?: number;
  }>;
  title?: string;
}

const { currentServerId, tags, servers, title = "Similar Servers You Might Like" } = Astro.props;

// Filter out current server and get related ones (matching at least one tag)
const relatedServers = servers
  .filter(s => s.id !== currentServerId)
  .map(s => ({
    ...s,
    matchCount: (s.tags || []).filter((t: string) => tags.includes(t)).length
  }))
  .filter(s => s.matchCount > 0)
  .sort((a, b) => b.matchCount - a.matchCount)
  .slice(0, 4);

// If no tag matches, just show popular servers
const displayServers = relatedServers.length > 0 
  ? relatedServers 
  : servers.filter(s => s.id !== currentServerId).slice(0, 4);

// Generate keywords for semantic linking
const keywordLinks = tags.slice(0, 3).map(tag => ({
  keyword: tag,
  url: `/category/${tag.toLowerCase()}`,
  label: `Browse more ${tag} servers`
}));
---

{displayServers.length > 0 && (
  <section class="mt-8 p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg" aria-labelledby="related-servers-heading">
    <h2 id="related-servers-heading" class="text-xl font-bold text-white mb-6 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#00f5d4]">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
      </svg>
      {title}
    </h2>
    
    <div class="grid gap-4 grid-cols-1 sm:grid-cols-2">
      {displayServers.map(server => (
        <a 
          href={`/servers/${server.id}`} 
          class="flex items-center gap-4 p-4 bg-[#1a1a25] border border-[#2a2a3a] hover:border-[#00f5d4] transition-colors rounded-lg group"
          rel="related"
        >
          {server.icon ? (
            <img 
              src={server.icon} 
              alt={`${server.name} Minecraft server icon`}
              class="w-12 h-12 rounded-lg object-cover flex-shrink-0 bg-[#12121a]"
              loading="lazy"
            />
          ) : (
            <div class="w-12 h-12 rounded-lg bg-[#12121a] flex items-center justify-center flex-shrink-0">
              <span class="text-[#00f5d4] text-xl">⛏</span>
            </div>
          )}
          
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-white group-hover:text-[#00f5d4] transition-colors truncate">
              {server.name}
            </h3>
            <p class="text-sm text-[#8892b0] font-mono truncate">
              {server.ip}:{server.port}
            </p>
            <div class="flex items-center gap-3 mt-1 text-xs text-[#8892b0]">
              <span class={server.status === 'online' ? 'text-green-500' : 'text-red-500'}>
                {server.status === 'online' ? '● Online' : '○ Offline'}
              </span>
              <span>{server.players_online || 0}/{server.max_players || '?'} players</span>
              <span class="text-[#ff3864]">▲ {server.vote_count || 0}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
    
    {/* Semantic keyword links for SEO */}
    {keywordLinks.length > 0 && (
      <div class="mt-6 pt-4 border-t border-[#2a2a3a]">
        <h3 class="text-sm text-[#8892b0] mb-3">Related Categories:</h3>
        <div class="flex flex-wrap gap-2">
          {keywordLinks.map(link => (
            <a 
              href={link.url}
              class="text-sm text-[#00f5d4] hover:underline"
              rel="tag"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
)}

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Related Servers to ${displayServers[0]?.name || 'Current Server'}`,
  "itemListElement": displayServers.map((server, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "GameServer",
      "name": server.name,
      "url": `https://guildpost.tech/servers/${server.id}`,
      "game": {
        "@type": "VideoGame",
        "name": "Minecraft"
      },
      "playerCount": {
        "@type": "QuantitativeValue",
        "value": server.players_online || 0
      }
    }
  }))
})} />
