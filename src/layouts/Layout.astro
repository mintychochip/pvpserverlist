---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
  keywords?: string;
}

const { 
  title, 
  description = 'GuildPost - Find your next multiplayer home. Discover the best Minecraft, Rust, and CS2 servers with live stats and community reviews.',
  image = 'https://guildpost.tech/og-image-new.png',
  url = 'https://guildpost.tech',
  type = 'website',
  keywords = 'minecraft servers, server list, minecraft multiplayer, game servers, rust servers, cs2 servers, minecraft server directory'
} = Astro.props;

const fullTitle = title === 'GuildPost' ? title : `${title} | GuildPost`;

// Environment configuration - injected for client-side use
const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="theme-color" content="#0a0a0f" id="theme-color-meta" />
    <meta name="color-scheme" content="dark light" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Theme CSS -->
    <link rel="stylesheet" href="/theme.css" />
    
    <!-- Supabase client library -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.47.10/dist/umd/supabase.min.js" defer></script>
    
    <!-- Theme initialization - prevents flash -->
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('guildpost-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = savedTheme || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        
        // Update meta theme-color based on theme
        const themeColors = {
          dark: '#0a0a0f',
          light: '#f8fafc',
          ocean: '#0c1220',
          sunset: '#1a0b0e',
          forest: '#0d1912',
          contrast: '#000000'
        };
        const metaThemeColor = document.getElementById('theme-color-meta');
        if (metaThemeColor && themeColors[theme]) {
          metaThemeColor.setAttribute('content', themeColors[theme]);
        }
        
        // Set RGB values for transparent backgrounds
        const rgbValues = {
          dark: '10, 10, 15',
          light: '248, 250, 252',
          ocean: '12, 18, 32',
          sunset: '26, 11, 14',
          forest: '13, 25, 18',
          contrast: '0, 0, 0'
        };
        document.documentElement.style.setProperty('--bg-primary-rgb', rgbValues[theme] || rgbValues.dark);
        
        // Set accent RGB values
        const accentRgbValues = {
          dark: { primary: '0, 245, 212', secondary: '255, 56, 100', tertiary: '168, 85, 247' },
          light: { primary: '8, 145, 178', secondary: '225, 29, 72', tertiary: '124, 58, 237' },
          ocean: { primary: '59, 130, 246', secondary: '139, 92, 246', tertiary: '6, 182, 212' },
          sunset: { primary: '249, 115, 22', secondary: '236, 72, 153', tertiary: '251, 191, 36' },
          forest: { primary: '16, 185, 129', secondary: '132, 204, 22', tertiary: '20, 184, 166' },
          contrast: { primary: '255, 255, 0', secondary: '0, 255, 255', tertiary: '255, 0, 255' }
        };
        const accents = accentRgbValues[theme] || accentRgbValues.dark;
        document.documentElement.style.setProperty('--accent-primary-rgb', accents.primary);
        document.documentElement.style.setProperty('--accent-secondary-rgb', accents.secondary);
        document.documentElement.style.setProperty('--accent-tertiary-rgb', accents.tertiary);
      })();
    </script>
    
    <!-- Global config for client-side scripts -->
    <script is:inline define:vars={{ supabaseUrl, supabaseKey }}>
      window.__CONFIG = {
        supabaseUrl: supabaseUrl,
        supabaseKey: supabaseKey
      };
    </script>
    
    <!-- Canonical URL -->
    <link rel="canonical" href={url} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/logo-icon-180.png" />
    <link rel="icon" type="image/svg+xml" href="/logo-icon.svg" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="GuildPost" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": type === 'website' ? 'WebSite' : 'WebPage',
      "name": fullTitle,
      "description": description,
      "url": url,
      "publisher": {
        "@type": "Organization",
        "name": "GuildPost",
        "url": "https://guildpost.tech",
        "logo": {
          "@type": "ImageObject",
          "url": "https://guildpost.tech/logo-icon-512.png"
        }
      }
    })} />
    
    <title>{fullTitle}</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Orbitron:wght@500;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- RSS Feeds -->
    <link rel="alternate" type="application/rss+xml" title="GuildPost Blog" href="https://guildpost.tech/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="GuildPost - New Minecraft Servers" href="https://guildpost.tech/rss/new.xml" />
    <link rel="alternate" type="application/rss+xml" title="GuildPost - Trending Servers" href="https://guildpost.tech/rss/popular.xml" />
    
    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" title="Sitemap" href="https://guildpost.tech/sitemap.xml" />
  </head>
  <body class="font-sans antialiased" style="background-color: var(--bg-primary); color: var(--text-primary);">
    <slot />
    
    <!-- Scroll to Top Button -->
    <button id="scroll-top" class="gp-scroll-top" aria-label="Scroll to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m18 15-6-6-6 6"/>
      </svg>
    </button>
    
    <!-- Toast Container -->
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>
    
    <script>
      // Scroll to top functionality
      const scrollTopBtn = document.getElementById('scroll-top');
      
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          scrollTopBtn?.classList.add('visible');
        } else {
          scrollTopBtn?.classList.remove('visible');
        }
      });
      
      scrollTopBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      
      // Toast notification system
      window.showToast = function(message, type = 'info', duration = 3000) {
        const container = document.getElementById('toast-container');
        
        const toast = document.createElement('div');
        toast.className = `pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-lg shadow-lg transform transition-all duration-300 translate-y-full opacity-0 ${
          type === 'success' ? 'bg-green-500 text-white' :
          type === 'error' ? 'bg-[#ff3864] text-white' :
          type === 'warning' ? 'bg-yellow-500 text-white' :
          'bg-[#00f5d4] text-[#0a0a0f]'
        }`;
        
        const icons = {
          success: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>',
          error: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg>',
          warning: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>',
          info: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="16" y2="12"/><line x1="12" x2="12.01" y1="8" y2="8"/></svg>'
        };
        
        toast.innerHTML = `
          ${icons[type]}
          <span class="font-medium">${message}</span>
          <button class="ml-2 opacity-70 hover:opacity-100" onclick="this.parentElement.remove()">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
            </svg>
          </button>
        `;
        
        container.appendChild(toast);
        
        // Animate in
        requestAnimationFrame(() => {
          toast.classList.remove('translate-y-full', 'opacity-0');
        });
        
        // Auto remove
        setTimeout(() => {
          toast.classList.add('translate-y-full', 'opacity-0');
          setTimeout(() => toast.remove(), 300);
        }, duration);
      };
    </script>
  </body>
</html>

<style is:global>
  :root {
    --void-black: #0a0a0f;
    --plasma-cyan: #00f5d4;
    --ember-pink: #ff3864;
    --text-muted: #8892b0;
    --border-color: #2a2a3a;
    font-family: 'Inter', system-ui, sans-serif;
  }
  
  .font-display {
    font-family: 'Orbitron', sans-serif;
  }
  
  .font-body {
    font-family: 'Space Grotesk', sans-serif;
  }
</style>
