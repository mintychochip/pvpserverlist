---
// Server Blog Feed Page - Shows all recent posts from all servers
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';

// Fetch recent posts with server info
let posts = [];
let error = null;

const categoryFilter = Astro.url.searchParams.get('category') || '';
const serverFilter = Astro.url.searchParams.get('server') || '';

// Category display names
const categoryLabels = {
  news: { label: 'News', emoji: '📰' },
  update: { label: 'Update', emoji: '🔄' },
  patch: { label: 'Patch Notes', emoji: '📦' },
  event: { label: 'Event', emoji: '🎉' },
  announcement: { label: 'Announcement', emoji: '📢' },
  other: { label: 'Other', emoji: '📝' }
};

try {
  // Build query for posts with server info
  let query = `${supabaseUrl}/rest/v1/server_posts?is_published=eq.true`;
  
  if (categoryFilter) {
    query += `&category=eq.${encodeURIComponent(categoryFilter)}`;
  }
  
  if (serverFilter) {
    query += `&server_id=eq.${encodeURIComponent(serverFilter)}`;
  }
  
  // Order by published_at desc, with pinned first
  query += '&order=is_pinned.desc, published_at.desc&limit=50';
  
  const response = await fetch(query, {
    headers: {
      'apikey': supabaseKey,
      'Authorization': `Bearer ${supabaseKey}`
    }
  });
  
  if (response.ok) {
    posts = await response.json();
    
    // Fetch server info for each post
    if (posts.length > 0) {
      const serverIds = [...new Set(posts.map(p => p.server_id))];
      const serversResponse = await fetch(
        `${supabaseUrl}/rest/v1/servers?id=in.(${serverIds.join(',')})&select=id,name,icon`,
        {
          headers: {
            'apikey': supabaseKey,
            'Authorization': `Bearer ${supabaseKey}`
          }
        }
      );
      
      if (serversResponse.ok) {
        const servers = await serversResponse.json();
        const serverMap = Object.fromEntries(servers.map(s => [s.id, s]));
        
        posts = posts.map(post => ({
          ...post,
          server: serverMap[post.server_id] || null
        }));
      }
    }
  } else {
    error = 'Failed to fetch posts';
  }
} catch (e) {
  error = e.message;
}

// Format date helper
const formatDate = (dateStr) => {
  const date = new Date(dateStr);
  const now = new Date();
  const diff = now - date;
  
  const hours = Math.floor(diff / (1000 * 60 * 60));
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  
  if (hours < 1) return 'Just now';
  if (hours < 24) return `${hours}h ago`;
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days} days ago`;
  
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
};

// Strip HTML tags for summary
const stripHtml = (html) => {
  return html?.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim() || '';
};
---

<Layout 
  title="Server News & Updates | GuildPost"
  description="Latest news, updates, and announcements from Minecraft servers on GuildPost."
  url="https://guildpost.tech/blog"
>
  <div class="min-h-screen" style="background-color: var(--bg-primary);">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-black text-white mb-2">📰 Server News & Updates</h1>
        <p class="text-[#8892b0]">Latest posts from Minecraft servers on GuildPost</p>
      </div>
      
      <!-- Category Filters -->
      <div class="flex flex-wrap gap-2 mb-8">
        <a 
          href="/blog" 
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
            !categoryFilter 
              ? 'bg-[#00f5d4] text-[#0a0a0f]' 
              : 'bg-[#1a1a25] text-[#8892b0] hover:text-white'
          }`}
        >
          All
        </a>
        {Object.entries(categoryLabels).map(([key, { label, emoji }]) => (
          <a 
            href={`/blog?category=${key}`}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              categoryFilter === key 
                ? 'bg-[#00f5d4] text-[#0a0a0f]' 
                : 'bg-[#1a1a25] text-[#8892b0] hover:text-white'
            }`}
          >
            {emoji} {label}
          </a>
        ))}
      </div>
      
      {error && (
        <div class="p-4 bg-red-500/20 border border-red-500/50 rounded-lg text-red-400 mb-6">
          {error}
        </div>
      )}
      
      <!-- Posts Grid -->
      {posts.length === 0 ? (
        <div class="p-12 bg-[#12121a] border border-[#2a2a3a] rounded-lg text-center">
          <p class="text-[#8892b0] text-lg mb-4">No posts yet</p>
          <p class="text-[#8892b0] text-sm">
            Server owners can create posts from their dashboard
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6">
          {posts.map(post => {
            const cat = categoryLabels[post.category] || categoryLabels.other;
            const summary = post.summary || stripHtml(post.content).substring(0, 200) + '...';
            
            return (
              <article class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg hover:border-[#00f5d4]/30 transition-colors group">
                <div class="flex items-start gap-4">
                  <!-- Server Icon -->
                  {post.server && (
                    <a href={`/servers/${post.server_id}`} class="flex-shrink-0">
                      <div class="w-14 h-14 bg-[#1a1a25] rounded-lg flex items-center justify-center overflow-hidden relative">
                        {post.server.icon ? (
                          <>
                            <img src={post.server.icon} alt="" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                            <span class="text-[#00f5d4] text-xl hidden absolute inset-0 items-center justify-center">⛏</span>
                          </>
                        ) : (
                          <span class="text-[#00f5d4] text-xl">⛏</span>
                        )}
                      </div>
                    </a>
                  )}
                  
                  <div class="flex-1 min-w-0">
                    <!-- Meta -->
                    <div class="flex items-center gap-3 mb-2 flex-wrap">
                      {post.is_pinned && (
                        <span class="px-2 py-0.5 bg-[#ff3864]/20 text-[#ff3864] text-xs font-bold rounded">
                          📌 PINNED
                        </span>
                      )}
                      <span class="px-2 py-0.5 bg-[#1a1a25] text-[#8892b0] text-xs rounded">
                        {cat.emoji} {cat.label}
                      </span>
                      {post.server && (
                        <a 
                          href={`/servers/${post.server_id}`}
                          class="text-[#00f5d4] text-sm hover:underline"
                        >
                          {post.server.name}
                        </a>
                      )}
                      <span class="text-[#8892b0] text-sm">•</span>
                      <span class="text-[#8892b0] text-sm">{formatDate(post.published_at)}</span>
                      <span class="text-[#8892b0] text-sm">•</span>
                      <span class="text-[#8892b0] text-sm">👁 {post.view_count || 0} views</span>
                    </div>
                    
                    <!-- Title -->
                    <a 
                      href={`/servers/${post.server_id}?post=${post.id}`}
                      class="block text-xl font-bold text-white mb-2 hover:text-[#00f5d4] transition-colors"
                    >
                      {post.title}
                    </a>
                    
                    <!-- Author -->
                    <p class="text-[#8892b0] text-sm mb-3">
                      By {post.author}
                    </p>
                    
                    <!-- Summary -->
                    <p class="text-[#8892b0] line-clamp-2 mb-4">
                      {summary}
                    </p>
                    
                    <!-- Read More -->
                    <a 
                      href={`/servers/${post.server_id}?post=${post.id}`}
                      class="inline-flex items-center gap-2 text-[#00f5d4] font-medium hover:underline"
                    >
                      Read more →
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </main>
    
    <Footer />
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
