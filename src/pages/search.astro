---
// Search Page - Intent-driven search with AI clarification
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SmartIntentSearch from '../components/SmartIntentSearch.astro';

// Get search query from URL
const query = Astro.url.searchParams.get('q') || '';
const game = Astro.url.searchParams.get('game') || 'minecraft';
const sort = Astro.url.searchParams.get('sort') || 'relevance';
---

<Layout 
  title={query ? `Search: "${query}" Minecraft Servers` : "Find Minecraft Servers | GuildPost"}
  description={query 
    ? `Search results for "${query}" Minecraft servers. Find the best ${query} servers with live status and player counts.`
    : "Search 2,000+ Minecraft servers. Find servers by name, IP, game mode, or version on GuildPost."
  }
  url={`https://guildpost.tech/search${query ? `?q=${encodeURIComponent(query)}` : ''}`}
  keywords={`minecraft server search, find minecraft servers, ${query} servers, server list search, minecraft multiplayer`}
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-[#8892b0] mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Search</span>
        {query && (
          <>
            <span>/</span>
            <span class="text-[#00f5d4]">{query}</span>
          </>
        )}
      </nav>

      <h1 class="text-4xl md:text-5xl font-black text-white mb-4">
        {query ? (
          <>Search Results for <span class="text-[#00f5d4]">"{query}"</span></>
        ) : (
          <>Find Your <span class="text-[#00f5d4]">Server</span></>
        )}
      </h1>
      
      <p class="text-[#8892b0] text-lg mb-8 max-w-2xl">
        {query 
          ? `Browse servers matching "${query}". Filter by game mode, version, and player count.`
          : "Search 2,000+ Minecraft servers by name, IP, or game mode."
        }
      </p>

      <!-- Intent-Driven Smart Search -->
      <div class="mb-8">
        <SmartIntentSearch id="intent-search" />
      </div>
      
      <!-- Or browse by category -->
      <div class="mb-8">
        <p class="text-[#8892b0] text-sm mb-3">Popular categories:</p>
        <div class="flex flex-wrap gap-2">
          {['PvP', 'Survival', 'Skyblock', 'Factions', 'SMP', 'Minigames', 'Hardcore', 'Creative'].map(tag => (
            <a 
              href={`/search?q=${tag.toLowerCase()}`}
              class="px-3 py-1.5 bg-[#12121a] border border-[#2a2a3a] text-[#00f5d4] rounded-lg text-sm hover:bg-[#2a2a3a] transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      </div>

      <!-- Browse all link -->
      <div class="text-center py-8">
        <p class="text-[#8892b0] mb-4">Want to browse instead?</p>
        <a 
          href="/minecraft" 
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#12121a] border border-[#2a2a3a] text-white rounded-lg hover:border-[#00f5d4] transition-colors"
        >
          <span>View All Servers</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<!-- SmartIntentSearch component handles all search logic -->