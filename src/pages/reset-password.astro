---
// Reset Password Page (from email link)
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Check for access token in URL (Supabase sends this)
const hasToken = Astro.url.hash.includes('access_token') || Astro.url.searchParams.has('token');
---

<Layout 
  title="Set New Password | GuildPost"
  description="Set a new password for your GuildPost account."
  url="https://guildpost.tech/reset-password"
>
  <div class="min-h-screen" style="background-color: var(--bg-primary);">
    <Header />
    
    <main class="max-w-md mx-auto px-4 py-16">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-black text-white mb-2">Set New Password</h1>
        <p class="text-[var(--text-secondary)]">Create a strong password for your account</p>
      </div>
      
      <div id="form-step" class="bg-[var(--bg-secondary)] border border-[var(--border-color)] rounded-xl p-6">
        <form id="reset-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1">New Password</label>
            <input 
              type="password" 
              id="password" 
              required
              minlength="8"
              class="w-full px-4 py-2 bg-[var(--bg-primary)] border border-[var(--border-color)] rounded-lg text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-primary)]"
              placeholder="••••••••"
            />
            <div class="mt-2 space-y-1">
              <div class="flex items-center text-xs" id="req-length">
                <span class="w-4 h-4 rounded-full bg-[var(--border-color)] flex items-center justify-center mr-2 text-[10px]">✓</span>
                <span class="text-[var(--text-muted)]">At least 8 characters</span>
              </div>
              <div class="flex items-center text-xs" id="req-uppercase">
                <span class="w-4 h-4 rounded-full bg-[var(--border-color)] flex items-center justify-center mr-2 text-[10px]">✓</span>
                <span class="text-[var(--text-muted)]">One uppercase letter</span>
              </div>
              <div class="flex items-center text-xs" id="req-number">
                <span class="w-4 h-4 rounded-full bg-[var(--border-color)] flex items-center justify-center mr-2 text-[10px]">✓</span>
                <span class="text-[var(--text-muted)]">One number</span>
              </div>
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1">Confirm Password</label>
            <input 
              type="password" 
              id="confirm-password" 
              required
              class="w-full px-4 py-2 bg-[var(--bg-primary)] border border-[var(--border-color)] rounded-lg text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-primary)]"
              placeholder="••••••••"
            />
          </div>
          
          <button 
            type="submit"
            id="submit-btn"
            class="w-full px-4 py-2 bg-[var(--accent-primary)] text-[var(--bg-primary)] font-semibold rounded-lg hover:opacity-90 transition-opacity"
          >
            Reset Password
          </button>
        </form>
        
        <div id="error" class="hidden mt-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg text-red-400 text-sm"></div>
      </div>
      
      <div id="success-step" class="hidden bg-[var(--bg-secondary)] border border-[var(--border-color)] rounded-xl p-6 text-center">
        <div class="w-16 h-16 bg-green-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <span class="text-3xl">✅</span>
        </div>
        <h2 class="text-xl font-bold text-white mb-2">Password Updated!</h2>
        <p class="text-[var(--text-secondary)] mb-6">
          Your password has been successfully reset. You'll need to sign in again on all devices.
        </p>
        <a 
          href="/login" 
          class="inline-block px-6 py-2 bg-[var(--accent-primary)] text-[var(--bg-primary)] font-semibold rounded-lg hover:opacity-90 transition-opacity"
        >
          Sign In
        </a>
      </div>
      
      <div id="invalid-step" class="hidden bg-[var(--bg-secondary)] border border-[var(--border-color)] rounded-xl p-6 text-center">
        <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <span class="text-3xl">⚠️</span>
        </div>
        <h2 class="text-xl font-bold text-white mb-2">Invalid or Expired Link</h2>
        <p class="text-[var(--text-secondary)] mb-6">
          This password reset link is invalid or has expired. Please request a new one.
        </p>
        <a 
          href="/forgot-password" 
          class="inline-block px-6 py-2 bg-[var(--accent-primary)] text-[var(--bg-primary)] font-semibold rounded-lg hover:opacity-90 transition-opacity"
        >
          Request New Link
        </a>
      </div>
    </main>
    
    <Footer />
  </div>
  
  <script>
    import { supabase, resetPassword } from '../lib/auth';
    
    const formStep = document.getElementById('form-step');
    const successStep = document.getElementById('success-step');
    const invalidStep = document.getElementById('invalid-step');
    const errorDiv = document.getElementById('error');
    
    // Check if we have a valid session from the reset link
    async function checkSession() {
      const { data: { session }, error } = await supabase.auth.getSession();
      
      if (error || !session) {
        formStep?.classList.add('hidden');
        invalidStep?.classList.remove('hidden');
      }
    }
    
    checkSession();
    
    // Password validation
    const passwordInput = document.getElementById('password') as HTMLInputElement;
    const confirmInput = document.getElementById('confirm-password') as HTMLInputElement;
    
    const reqLength = document.getElementById('req-length');
    const reqUppercase = document.getElementById('req-uppercase');
    const reqNumber = document.getElementById('req-number');
    
    function updateIndicators(password: string) {
      const hasLength = password.length >= 8;
      const hasUppercase = /[A-Z]/.test(password);
      const hasNumber = /[0-9]/.test(password);
      
      function setValid(el: HTMLElement | null, valid: boolean) {
        if (!el) return;
        const dot = el.querySelector('span:first-child');
        if (dot) {
          dot.className = `w-4 h-4 rounded-full flex items-center justify-center mr-2 text-[10px] ${valid ? 'bg-green-500 text-white' : 'bg-[var(--border-color)]'}`;
        }
        const text = el.querySelector('span:last-child');
        if (text) {
          text.className = valid ? 'text-green-400' : 'text-[var(--text-muted)]';
        }
      }
      
      setValid(reqLength, hasLength);
      setValid(reqUppercase, hasUppercase);
      setValid(reqNumber, hasNumber);
    }
    
    passwordInput?.addEventListener('input', (e) => {
      updateIndicators((e.target as HTMLInputElement).value);
    });
    
    // Form submission
    const form = document.getElementById('reset-form') as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const password = passwordInput.value;
      const confirmPassword = confirmInput.value;
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      
      if (password !== confirmPassword) {
        errorDiv?.classList.remove('hidden');
        if (errorDiv) errorDiv.textContent = 'Passwords do not match';
        return;
      }
      
      if (password.length < 8) {
        errorDiv?.classList.remove('hidden');
        if (errorDiv) errorDiv.textContent = 'Password must be at least 8 characters';
        return;
      }
      
      btn.disabled = true;
      btn.textContent = 'Updating...';
      
      try {
        const result = await resetPassword(password);
        
        if (result.success) {
          formStep?.classList.add('hidden');
          successStep?.classList.remove('hidden');
        } else {
          errorDiv?.classList.remove('hidden');
          if (errorDiv) errorDiv.textContent = result.error || 'Failed to reset password';
        }
      } catch (err) {
        errorDiv?.classList.remove('hidden');
        if (errorDiv) errorDiv.textContent = 'An error occurred. Please try again.';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Reset Password';
      }
    });
  </script>
</Layout>