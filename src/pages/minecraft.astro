---
// Minecraft Servers Page - Enhanced with Search, Filters, and Pagination
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const VALID_CATEGORIES = [
  'Survival', 'SMP', 'PvP', 'Skyblock', 'Factions', 
  'Prison', 'Minigames', 'Creative', 'Hardcore', 
  'Anarchy', 'RPG', 'Modded', 'Pixelmon', 'Multiplayer',
  'Bedwars', 'Towny', 'Economy', 'Roleplay', 'Bedrock', 'Cross-Play'
];
---

<Layout 
  title="Minecraft Servers - Find PvP, Survival, Skyblock & More | GuildPost"
  description="Browse 2,000+ Minecraft servers on GuildPost. Find PvP, Survival, Skyblock, Factions, SMP, Minigames & more. Live player counts, voting, and detailed server info."
  url="https://guildpost.tech/minecraft"
  keywords="minecraft servers, minecraft server list, pvp servers, survival servers, skyblock, factions, smp, minecraft multiplayer, best minecraft servers"
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-[#8892b0] mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Minecraft</span>
      </nav>

      <h1 class="text-4xl font-black text-white mb-4">
        Minecraft Servers
      </h1>
      <p class="text-[#8892b0] text-lg mb-8 max-w-2xl">
        Discover thousands of Minecraft multiplayer servers. Browse by game mode, 
        search by name, or filter by player count and version.
      </p>

      <!-- Search & Filters -->
      <div class="mb-8 p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
        <div class="flex flex-col md:flex-row gap-4">
          <!-- Search -->
          <div class="flex-1 relative">
            <input 
              type="text" 
              id="search-input" 
              placeholder="Search servers by name, IP, or describe what you're looking for..." 
              class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4] pr-28"
            >
            <!-- AI Search Toggle -->
            <button 
              id="ai-search-toggle"
              class="absolute right-2 top-1/2 transform -translate-y-1/2 px-3 py-1.5 bg-[#1a1a25] hover:bg-[#2a2a3a] text-xs text-[#8892b0] rounded border border-[#2a2a3a] transition-all flex items-center gap-1.5"
              title="Toggle AI-powered semantic search (powered by Gemini)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
              <span class="ai-label">Semantic</span>
            </button>
          </div>
          
          <!-- Sort -->
          <select 
            id="sort-select"
            class="px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4]"
          >
            <option value="votes">Most Votes</option>
            <option value="players">Most Players</option>
            <option value="newest">Newest First</option>
            <option value="name">Name A-Z</option>
          </select>
          
          <!-- Status Filter -->
          <select 
            id="status-select"
            class="px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4]"
          >
            <option value="all">All Servers</option>
            <option value="online">Online Only</option>
            <option value="offline">Offline</option>
          </select>
          
          <!-- Version Filter -->
          <select 
            id="version-select"
            class="px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4]"
          >
            <option value="all">All Versions</option>
            <option value="1.21">1.21.x</option>
            <option value="1.20">1.20.x</option>
            <option value="1.19">1.19.x</option>
            <option value="1.18">1.18.x</option>
            <option value="1.17">1.17.x</option>
            <option value="1.16">1.16.x</option>
            <option value="1.12">1.12.x</option>
          </select>
          
          <!-- Platform Filter -->
          <select 
            id="platform-select"
            class="px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4]"
          >
            <option value="all">All Platforms</option>
            <option value="java">☕ Java Edition</option>
            <option value="bedrock">⛏️ Bedrock Edition</option>
            <option value="crossplay">🌐 Cross-Play</option>
          </select>
          
          <!-- Country Filter -->
          <select 
            id="country-select"
            class="px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4]"
          >
            <option value="all">All Countries</option>
            <option value="US">🇺🇸 USA</option>
            <option value="DE">🇩🇪 Germany</option>
            <option value="GB">🇬🇧 UK</option>
            <option value="CA">🇨🇦 Canada</option>
            <option value="AU">🇦🇺 Australia</option>
            <option value="NL">🇳🇱 Netherlands</option>
            <option value="FR">🇫🇷 France</option>
            <option value="BR">🇧🇷 Brazil</option>
            <option value="RU">🇷🇺 Russia</option>
            <option value="JP">🇯🇵 Japan</option>
          </select>
        </div>
        
        <!-- Active Filters -->
        <div id="active-filters" class="flex flex-wrap items-center gap-2 mt-4 hidden">
          <span class="text-[#8892b0] text-sm">Filters:</span>
          <div id="filter-chips" class="flex flex-wrap gap-2"></div>
          <button id="clear-filters-inline" class="text-[#ff3864] hover:text-[#e63357] text-sm">Clear all</button>
        </div>
      </div>

      <!-- Categories -->
      <div class="mb-8">
        <h2 class="text-lg font-bold text-white mb-3">Browse by Category</h2>
        <div id="categories" class="flex flex-wrap gap-2">
          {VALID_CATEGORIES.map(category => (
            <button 
              onclick="filterByTag('${category}')"
              class="quick-filter px-3 py-1.5 bg-[#1a1a25] hover:bg-[#00f5d4]/20 hover:text-[#00f5d4] text-[#8892b0] rounded-lg text-sm transition-colors border border-transparent"
              data-tag="${category}"
            >
              {category}
            </button>
          ))}
        </div>
      </div>

      <!-- Servers Count -->
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold text-white">
          Servers 
          <span id="server-count" class="text-[#8892b0] text-sm font-normal ml-2">(Loading...)</span>
        </h2>
        <div id="pagination-info" class="text-[#8892b0] text-sm"></div>
      </div>

      <!-- Servers Grid -->
      <div id="servers-list" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Skeleton Loading State -->
        {Array(9).fill(0).map(() => (
          <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg animate-pulse">
            <div class="flex items-start gap-3">
              <div class="w-12 h-12 bg-[#1a1a25] rounded-lg"></div>
              <div class="flex-1 space-y-2">
                <div class="h-4 bg-[#1a1a25] rounded w-3/4"></div>
                <div class="h-3 bg-[#1a1a25] rounded w-1/2"></div>
                <div class="flex gap-2 mt-3">
                  <div class="h-3 bg-[#1a1a25] rounded w-16"></div>
                  <div class="h-3 bg-[#1a1a25] rounded w-16"></div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Pagination -->
      <div id="pagination" class="flex flex-wrap items-center justify-center gap-2 mt-8 hidden">
        <button id="prev-page" class="px-4 py-2 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors flex-shrink-0">
          ← Prev
        </button>
        <div id="page-numbers" class="flex flex-wrap items-center justify-center gap-1 max-w-[300px]">
          <!-- Page numbers -->
        </div>
        <button id="next-page" class="px-4 py-2 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors flex-shrink-0">
          Next →
        </button>
      </div>

      <!-- No Results -->
      <div id="no-results" class="hidden text-center py-16">
        <div class="w-20 h-20 bg-[#1a1a25] rounded-full flex items-center justify-center mx-auto mb-6 relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#8892b0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
          <div class="absolute -bottom-1 -right-1 w-8 h-8 bg-[#12121a] rounded-full flex items-center justify-center border-2 border-[#0a0a0f]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ff3864" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </div>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">No servers match your search</h3>
        <p class="text-[#8892b0] mb-6 max-w-md mx-auto">Try different keywords, check your spelling, or clear your filters to see all available servers.</p>
        <div class="flex gap-3 justify-center">
          <button id="clear-filters-btn" class="px-4 py-2 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 6h18"/><path d="M7 12h10"/><path d="M10 18h4"/>
            </svg>
            Clear Filters
          </button>
          <a href="/minecraft" class="px-4 py-2 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors">
            Browse All
          </a>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';
  
  const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
  const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndweHV0c2RiaWFtcG54ZmdrandxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNTEwMDQsImV4cCI6MjA5MDkyNzAwNH0.35hrTSgxQnICpLOY3g6W3eNxxe7DKCc3q165tyb0Ieo';
  
  // State
  let allServers = [];
  let filteredServers = [];
  let currentPage = 1;
  const SERVERS_PER_PAGE = 18;
  
  // Elements
  const searchInput = document.getElementById('search-input');
  const sortSelect = document.getElementById('sort-select');
  const statusSelect = document.getElementById('status-select');
  const versionSelect = document.getElementById('version-select');
  const platformSelect = document.getElementById('platform-select');
  const countrySelect = document.getElementById('country-select');
  const serversList = document.getElementById('servers-list');
  const serverCount = document.getElementById('server-count');
  const paginationInfo = document.getElementById('pagination-info');
  const pagination = document.getElementById('pagination');
  const prevPageBtn = document.getElementById('prev-page');
  const nextPageBtn = document.getElementById('next-page');
  const pageNumbers = document.getElementById('page-numbers');
  const noResults = document.getElementById('no-results');
  const activeFiltersDiv = document.getElementById('active-filters');
  const filterChips = document.getElementById('filter-chips');
  
  async function loadServers() {
    const supabase = createClient(supabaseUrl, supabaseKey);
    
    const { data: servers, error } = await supabase
      .from('servers')
      .select('*')
      .order('vote_count', { ascending: false });
    
    if (error) {
      console.error('Error loading servers:', error);
      serversList.innerHTML = `
        <div class="col-span-full text-center py-16">
          <div class="w-20 h-20 bg-[#ff3864]/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ff3864" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Failed to load servers</h3>
          <p class="text-[#8892b0] mb-6">Something went wrong while fetching the server list.</p>
          <button onclick="location.reload()" class="px-6 py-3 bg-[#ff3864] hover:bg-[#e63357] text-white font-bold rounded-lg transition-colors flex items-center gap-2 mx-auto">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
              <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
              <path d="M16 16h5v5"/>
            </svg>
            Try Again
          </button>
        </div>
      `;
      return;
    }
    
    allServers = servers || [];
    filteredServers = [...allServers];
    
    applyFilters();
  }
  
  function applyFilters() {
    let results = [...allServers];
    
    // Search filter
    const searchTerm = searchInput.value.toLowerCase().trim();
    if (searchTerm) {
      results = results.filter(s => 
        s.name?.toLowerCase().includes(searchTerm) ||
        s.ip?.toLowerCase().includes(searchTerm) ||
        s.tags?.some(t => t.toLowerCase().includes(searchTerm))
      );
    }
    
    // Status filter
    const statusFilter = statusSelect.value;
    if (statusFilter !== 'all') {
      results = results.filter(s => s.status === statusFilter);
    }
    
    // Version filter
    const versionFilter = versionSelect.value;
    if (versionFilter !== 'all') {
      results = results.filter(s => {
        const v = s.version_normalized || s.version || '';
        return v.startsWith(versionFilter);
      });
    }
    
    // Country filter
    const countryFilter = countrySelect.value;
    if (countryFilter !== 'all') {
      results = results.filter(s => s.country_code === countryFilter);
    }
    
    // Platform filter (edition)
    const platformFilter = platformSelect.value;
    if (platformFilter !== 'all') {
      results = results.filter(s => {
        const edition = (s.edition || 'java').toLowerCase();
        if (platformFilter === 'crossplay') {
          return edition === 'crossplay' || edition === 'both' || edition === 'java+bedrock';
        }
        return edition === platformFilter;
      });
    }
    
    // Sort
    const sortBy = sortSelect.value;
    results.sort((a, b) => {
      switch (sortBy) {
        case 'votes':
          return (b.vote_count || 0) - (a.vote_count || 0);
        case 'players':
          return (b.players_online || 0) - (a.players_online || 0);
        case 'newest':
          return new Date(b.created_at) - new Date(a.created_at);
        case 'name':
          return (a.name || '').localeCompare(b.name || '');
        default:
          return 0;
      }
    });
    
    filteredServers = results;
    currentPage = 1;
    
    updateDisplay();
  }
  
  function updateDisplay() {
    // Update count
    serverCount.textContent = `(${filteredServers.length.toLocaleString()} found)`;
    
    // Check for no results
    if (filteredServers.length === 0) {
      serversList.innerHTML = '';
      pagination.classList.add('hidden');
      noResults.classList.remove('hidden');
      return;
    }
    
    noResults.classList.add('hidden');
    
    // Pagination
    const totalPages = Math.ceil(filteredServers.length / SERVERS_PER_PAGE);
    const startIndex = (currentPage - 1) * SERVERS_PER_PAGE;
    const endIndex = startIndex + SERVERS_PER_PAGE;
    const pageServers = filteredServers.slice(startIndex, endIndex);
    
    // Update pagination info
    paginationInfo.textContent = `Showing ${startIndex + 1}-${Math.min(endIndex, filteredServers.length)} of ${filteredServers.length}`;
    
    // Render servers
    serversList.innerHTML = pageServers.map(server => {
      // Get platform badge
      const edition = (server.edition || 'java').toLowerCase();
      let platformBadge = '';
      if (edition === 'bedrock') {
        platformBadge = `<span class="px-1.5 py-0.5 bg-[#8b5cf6]/20 text-[#8b5cf6] rounded text-[10px] font-bold flex items-center gap-1" title="Bedrock Edition">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 20H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1"/><path d="M12 16l-4 4 4 4"/><path d="M8 20h8"/><path d="m6 6 6 6 6-6"/></svg>
          BEDROCK
        </span>`;
      } else if (edition === 'crossplay' || edition === 'both' || edition === 'java+bedrock') {
        platformBadge = `<span class="px-1.5 py-0.5 bg-[#f59e0b]/20 text-[#f59e0b] rounded text-[10px] font-bold flex items-center gap-1" title="Cross-Play (Java + Bedrock)">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          CROSS-PLAY
        </span>`;
      } else {
        platformBadge = `<span class="px-1.5 py-0.5 bg-[#f59e0b]/20 text-[#f59e0b] rounded text-[10px] font-bold flex items-center gap-1" title="Java Edition">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>
          JAVA
        </span>`;
      }
      
      return `
      <div class="p-4 bg-[#12121a] border border-[#2a2a3a] hover:border-[#00f5d4] rounded-lg transition-all group" data-server-id="${server.id}">
        <a href="/servers/${server.id}" class="block">
          <div class="flex items-start gap-3">
            <div class="relative w-12 h-12 bg-[#1a1a25] rounded-lg flex items-center justify-center flex-shrink-0">
              ${server.icon ? 
                `<img src="${server.icon}" alt="" class="w-full h-full object-cover rounded-lg">` : 
                `<span class="text-[#00f5d4] text-xl">⛏</span>`
              }
              ${server.status === 'online' ? 
                `<span class="absolute -top-1 -right-1 w-3 h-3 bg-green-500 rounded-full border-2 border-[#12121a]"></span>` : 
                `<span class="absolute -top-1 -right-1 w-3 h-3 bg-gray-500 rounded-full border-2 border-[#12121a]"></span>`
              }
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <h3 class="font-bold text-white group-hover:text-[#00f5d4] transition-colors truncate">${server.name || 'Unnamed Server'}</h3>
                ${server.verified ? `<span class="text-[#00f5d4]" title="Verified Server">✓</span>` : ''}
              </div>
              <p class="text-[#8892b0] text-sm truncate">${server.ip}:${server.port}</p>
              
              <div class="flex items-center gap-3 mt-2 text-xs flex-wrap">
                <span class="${server.status === 'online' ? 'text-green-500' : 'text-gray-500'}">
                  ${server.status === 'online' ? '● Online' : '○ Offline'}
                </span>
                <span class="text-[#8892b0]">
                  ${server.players_online || 0}/${server.max_players || '?'} players
                </span>
                <span class="text-[#ff3864]">
                  ▲ ${server.vote_count || 0}
                </span>
                ${server.version ? `<span class="text-[#00f5d4]">${server.version}</span>` : ''}
                ${server.country_code ? `<span class="text-[#8892b0]">${getCountryFlag(server.country_code)}</span>` : ''}
                ${platformBadge}
                ${server.tier === 'premium' ? `<span class="px-1.5 py-0.5 bg-[#00f5d4]/20 text-[#00f5d4] rounded text-[10px] font-bold">PREMIUM</span>` : ''}
                ${server.tier === 'elite' ? `<span class="px-1.5 py-0.5 bg-[#a855f7]/20 text-[#a855f7] rounded text-[10px] font-bold">ELITE</span>` : ''}
              </div>
              
              ${server.tags?.length ? `
                <div class="flex flex-wrap gap-1 mt-2">
                  ${server.tags.slice(0, 3).map(tag => `
                    <span class="px-2 py-0.5 bg-[#1a1a25] text-[#8892b0] rounded text-xs">${tag}</span>
                  `).join('')}
                </div>
              ` : ''}
            </div>
          </div>
        </a>
        
        <!-- Action Buttons -->
        <div class="flex items-center gap-2 mt-3 pt-3 border-t border-[#2a2a3a]">
          <button 
            onclick="copyServerIP('${server.ip}:${server.port}', this)"
            class="flex-1 py-2 px-3 bg-[#1a1a25] hover:bg-[#2a2a3a] text-[#8892b0] hover:text-white rounded text-sm transition-colors flex items-center justify-center gap-1"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span class="copy-text">Copy IP</span>
          </button>
          <button 
            onclick="quickAddToCompare('${server.id}')"
            class="py-2 px-3 bg-[#1a1a25] hover:bg-[#2a2a3a] text-[#8892b0] hover:text-white rounded text-sm transition-colors"
            title="Add to Compare"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 6h18"/><path d="M7 12h10"/><path d="M10 18h4"/>
            </svg>
          </button>
        </div>
      </div>
    `).join('');
    
    // Re-attach copy functionality
    window.copyServerIP = async (ip, btn) => {
      await navigator.clipboard.writeText(ip);
      const textSpan = btn.querySelector('.copy-text');
      textSpan.textContent = 'Copied!';
      btn.classList.add('text-green-500');
      setTimeout(() => {
        textSpan.textContent = 'Copy IP';
        btn.classList.remove('text-green-500');
      }, 2000);
    };
    
    window.quickAddToCompare = (id) => {
      let compare = JSON.parse(localStorage.getItem('guildpost_compare') || '[]');
      if (!compare.includes(id)) {
        if (compare.length >= 4) {
          showToast('Compare list full (max 4)', 'warning');
          return;
        }
        compare.push(id);
        localStorage.setItem('guildpost_compare', JSON.stringify(compare));
        showToast('Added to compare list', 'success');
      } else {
        showToast('Already in compare list', 'info');
      }
    };
    
    // Update pagination controls
    prevPageBtn.disabled = currentPage === 1;
    nextPageBtn.disabled = currentPage === totalPages || totalPages === 0;
    
    // Page numbers - show limited window around current page
    pageNumbers.innerHTML = '';
    const maxVisible = 5; // Show 5 page buttons max
    let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
    let endPage = Math.min(totalPages, startPage + maxVisible - 1);
    
    // Adjust if we're near the end
    if (endPage - startPage + 1 < maxVisible) {
      startPage = Math.max(1, endPage - maxVisible + 1);
    }
    
    // First page + ellipsis if needed
    if (startPage > 1) {
      const firstBtn = document.createElement('button');
      firstBtn.textContent = '1';
      firstBtn.className = 'w-10 h-10 rounded-lg text-sm bg-[#1a1a25] hover:bg-[#2a2a3a] text-white transition-colors';
      firstBtn.addEventListener('click', () => { currentPage = 1; updateDisplay(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
      pageNumbers.appendChild(firstBtn);
      
      if (startPage > 2) {
        const ellipsis = document.createElement('span');
        ellipsis.textContent = '...';
        ellipsis.className = 'px-2 text-[#8892b0]';
        pageNumbers.appendChild(ellipsis);
      }
    }
    
    // Visible page range
    for (let i = startPage; i <= endPage; i++) {
      const btn = document.createElement('button');
      btn.textContent = i;
      btn.className = `w-10 h-10 rounded-lg text-sm transition-colors ${
        i === currentPage 
          ? 'bg-[#00f5d4] text-[#0a0a0f] font-bold' 
          : 'bg-[#1a1a25] hover:bg-[#2a2a3a] text-white'
      }`;
      btn.addEventListener('click', () => {
        currentPage = i;
        updateDisplay();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      pageNumbers.appendChild(btn);
    }
    
    // Last page + ellipsis if needed
    if (endPage < totalPages) {
      if (endPage < totalPages - 1) {
        const ellipsis = document.createElement('span');
        ellipsis.textContent = '...';
        ellipsis.className = 'px-2 text-[#8892b0]';
        pageNumbers.appendChild(ellipsis);
      }
      
      const lastBtn = document.createElement('button');
      lastBtn.textContent = totalPages;
      lastBtn.className = 'w-10 h-10 rounded-lg text-sm bg-[#1a1a25] hover:bg-[#2a2a3a] text-white transition-colors';
      lastBtn.addEventListener('click', () => { currentPage = totalPages; updateDisplay(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
      pageNumbers.appendChild(lastBtn);
    }
    
    pagination.classList.remove('hidden');
    
    // Update active filters display
    updateActiveFilters();
  }
  
  // Quick filter by tag
  window.filterByTag = (tag) => {
    searchInput.value = tag;
    applyFilters();
    updateActiveFilters();
  };
  
  window.clearAllFilters = () => {
    searchInput.value = '';
    sortSelect.value = 'votes';
    statusSelect.value = 'all';
    versionSelect.value = 'all';
    platformSelect.value = 'all';
    countrySelect.value = 'all';
    applyFilters();
    updateActiveFilters();
  };
  
  function updateActiveFilters() {
    const filters = [];
    
    if (searchInput.value) filters.push({ type: 'search', value: searchInput.value });
    if (statusSelect.value !== 'all') filters.push({ type: 'status', value: statusSelect.value });
    if (versionSelect.value !== 'all') filters.push({ type: 'version', value: `${versionSelect.value}.x` });
    if (platformSelect.value !== 'all') {
      const platformLabels = { java: '☕ Java', bedrock: '⛏️ Bedrock', crossplay: '🌐 Cross-Play' };
      filters.push({ type: 'platform', value: platformLabels[platformSelect.value] || platformSelect.value });
    }
    if (countrySelect.value !== 'all') {
      const countryOption = countrySelect.options[countrySelect.selectedIndex];
      filters.push({ type: 'country', value: countryOption.text.replace(/[^\w\s]/g, '').trim() });
    }
    
    if (filters.length === 0) {
      activeFiltersDiv.classList.add('hidden');
      return;
    }
    
    activeFiltersDiv.classList.remove('hidden');
    filterChips.innerHTML = filters.map(f => `
      <span class="px-2 py-1 bg-[#00f5d4]/20 text-[#00f5d4] rounded text-xs flex items-center gap-1">
        ${f.type === 'search' ? '🔍' : '●'} ${f.value}
      </span>
    `).join('');
  }
  
  // Clear filters buttons
  document.getElementById('clear-filters-btn')?.addEventListener('click', clearAllFilters);
  document.getElementById('clear-filters-inline')?.addEventListener('click', clearAllFilters);
  
  // Event listeners
  searchInput?.addEventListener('input', debounce(applyFilters, 300));
  sortSelect?.addEventListener('change', applyFilters);
  statusSelect?.addEventListener('change', applyFilters);
  versionSelect?.addEventListener('change', applyFilters);
  platformSelect?.addEventListener('change', applyFilters);
  countrySelect?.addEventListener('change', applyFilters);
  
  prevPageBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      updateDisplay();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
  
  nextPageBtn?.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredServers.length / SERVERS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage++;
      updateDisplay();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
  
  function debounce(fn, delay) {
    let timeout;
    return (...args) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => fn(...args), delay);
    };
  }
  
  // Country flag emoji helper
  function getCountryFlag(countryCode) {
    if (!countryCode) return '';
    const codePoints = countryCode
      .toUpperCase()
      .split('')
      .map(char => 127397 + char.charCodeAt(0));
    return String.fromCodePoint(...codePoints);
  }
  
  // AI-Powered Semantic Search (Gemini)
  let aiSearchEnabled = false;
  const aiSearchToggle = document.getElementById('ai-search-toggle');
  
  // Update toggle UI
  function updateAIToggleUI() {
    if (aiSearchEnabled) {
      aiSearchToggle.classList.add('bg-[#00f5d4]/20', 'border-[#00f5d4]', 'text-[#00f5d4]');
      aiSearchToggle.classList.remove('text-[#8892b0]', 'border-[#2a2a3a]');
      aiSearchToggle.querySelector('.ai_label') || (aiSearchToggle.querySelector('.ai-label').textContent = 'Semantic');
      searchInput.placeholder = "Describe what you're looking for (e.g., 'pvp factions with economy')...";
    } else {
      aiSearchToggle.classList.remove('bg-[#00f5d4]/20', 'border-[#00f5d4]', 'text-[#00f5d4]');
      aiSearchToggle.classList.add('text-[#8892b0]', 'border-[#2a2a3a]');
      searchInput.placeholder = "Search servers by name, IP, or describe what you're looking for...";
    }
  }
  
  aiSearchToggle?.addEventListener('click', () => {
    aiSearchEnabled = !aiSearchEnabled;
    updateAIToggleUI();
    
    if (aiSearchEnabled) {
      showToast('AI semantic search enabled (Gemini)', 'info');
    }
  });
  
  // Store original applyFilters
  const originalApplyFilters = applyFilters;
  
  // Override applyFilters for AI search
  applyFilters = async function() {
    if (!aiSearchEnabled) {
      return originalApplyFilters();
    }
    
    const query = searchInput.value.trim();
    
    if (!query) {
      return originalApplyFilters();
    }
    
    // Show loading state
    serversList.innerHTML = Array(6).fill(`
      <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg animate-pulse">
        <div class="flex items-start gap-3">
          <div class="w-12 h-12 bg-[#1a1a25] rounded-lg"></div>
          <div class="flex-1 space-y-2">
            <div class="h-4 bg-[#1a1a25] rounded w-3/4"></div>
            <div class="h-3 bg-[#1a1a25] rounded w-1/2"></div>
          </div>
        </div>
      </div>
    `).join('');
    
    try {
      const response = await fetch('/api/search/semantic', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query, limit: 50 })
      });
      
      if (!response.ok) {
        const error = await response.json().catch(() => ({}));
        throw new Error(error.error || 'AI search failed');
      }
      
      const data = await response.json();
      filteredServers = data.results || [];
      
      // Apply status filter
      const statusFilter = statusSelect.value;
      if (statusFilter !== 'all') {
        filteredServers = filteredServers.filter(s => s.status === statusFilter);
      }
      
      currentPage = 1;
      updateDisplay();
      
      if (data.semantic && filteredServers.length > 0) {
        showToast(`Found ${filteredServers.length} servers matching "${query}"`, 'success');
      } else if (filteredServers.length === 0) {
        showToast('No semantic matches found, try different keywords', 'warning');
      }
    } catch (err) {
      console.error('AI search error:', err);
      showToast('AI search unavailable, using regular search', 'warning');
      return originalApplyFilters();
    }
  };
  
  // Load on mount
  loadServers();
</script>
