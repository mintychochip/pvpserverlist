---
// Registration Page
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const redirectTo = Astro.url.searchParams.get('redirect') || '/dashboard';
---

<Layout 
  title="Create Account | GuildPost"
  description="Create a GuildPost account to claim your Minecraft server and access premium features."
  url="https://guildpost.tech/register"
>
  <div class="min-h-screen" style="background-color: var(--bg-primary);">
    <Header />
    
    <main class="max-w-md mx-auto px-4 py-16">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-black text-white mb-2">Create Account</h1>
        <p class="text-[var(--text-secondary)]">Join GuildPost to manage your servers</p>
      </div>
      
      <div class="bg-[var(--bg-secondary)] border border-[var(--border-color)] rounded-xl p-6">
        <form id="register-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1">Email</label>
            <input 
              type="email" 
              id="email" 
              required
              class="w-full px-4 py-2 bg-[var(--bg-primary)] border border-[var(--border-color)] rounded-lg text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-primary)]"
              placeholder="you@example.com"
            />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1">Username</label>
            <input 
              type="text" 
              id="username" 
              required
              minlength="3"
              maxlength="20"
              class="w-full px-4 py-2 bg-[var(--bg-primary)] border border-[var(--border-color)] rounded-lg text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-primary)]"
              placeholder="minecraftpro"
            />
            <p class="text-xs text-[var(--text-muted)] mt-1">3-20 characters, letters and numbers only</p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1">Password</label>
            <input 
              type="password" 
              id="password" 
              required
              minlength="8"
              class="w-full px-4 py-2 bg-[var(--bg-primary)] border border-[var(--border-color)] rounded-lg text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-primary)]"
              placeholder="••••••••"
            />
            <div class="mt-2 space-y-1">
              <div class="flex items-center text-xs" id="req-length">
                <span class="w-4 h-4 rounded-full bg-[var(--border-color)] flex items-center justify-center mr-2 text-[10px]">✓</span>
                <span class="text-[var(--text-muted)]">At least 8 characters</span>
              </div>
              <div class="flex items-center text-xs" id="req-uppercase">
                <span class="w-4 h-4 rounded-full bg-[var(--border-color)] flex items-center justify-center mr-2 text-[10px]">✓</span>
                <span class="text-[var(--text-muted)]">One uppercase letter</span>
              </div>
              <div class="flex items-center text-xs" id="req-number">
                <span class="w-4 h-4 rounded-full bg-[var(--border-color)] flex items-center justify-center mr-2 text-[10px]">✓</span>
                <span class="text-[var(--text-muted)]">One number</span>
              </div>
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1">Confirm Password</label>
            <input 
              type="password" 
              id="confirm-password" 
              required
              class="w-full px-4 py-2 bg-[var(--bg-primary)] border border-[var(--border-color)] rounded-lg text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-primary)]"
              placeholder="••••••••"
            />
          </div>
          
          <div class="flex items-start">
            <input 
              type="checkbox" 
              id="terms" 
              required
              class="mt-1 mr-2"
            />
            <label for="terms" class="text-sm text-[var(--text-secondary)]">
              I agree to the <a href="/terms" class="text-[var(--accent-primary)] hover:underline">Terms of Service</a> and <a href="/privacy" class="text-[var(--accent-primary)] hover:underline">Privacy Policy</a>
            </label>
          </div>
          
          <button 
            type="submit"
            id="register-btn"
            class="w-full px-4 py-2 bg-[var(--accent-primary)] text-[var(--bg-primary)] font-semibold rounded-lg hover:opacity-90 transition-opacity"
          >
            Create Account
          </button>
        </form>
        
        <div id="register-error" class="hidden mt-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg text-red-400 text-sm"></div>
        
        <div id="register-success" class="hidden mt-4 p-3 bg-green-500/10 border border-green-500/30 rounded-lg text-green-400 text-sm">
          Account created! Check your email to verify your account.
        </div>
        
        <div class="mt-6 text-center text-sm text-[var(--text-secondary)]">
          Already have an account? 
          <a href="/login" class="text-[var(--accent-primary)] hover:underline">Sign in</a>
        </div>
      </div>
    </main>
    
    <Footer />
  </div>
  
  <script>
    import { register } from '../lib/auth';
    
    const form = document.getElementById('register-form') as HTMLFormElement;
    const passwordInput = document.getElementById('password') as HTMLInputElement;
    const confirmInput = document.getElementById('confirm-password') as HTMLInputElement;
    const errorDiv = document.getElementById('register-error');
    const successDiv = document.getElementById('register-success');
    
    // Password strength indicators
    const reqLength = document.getElementById('req-length');
    const reqUppercase = document.getElementById('req-uppercase');
    const reqNumber = document.getElementById('req-number');
    
    function updatePasswordIndicators(password: string) {
      const hasLength = password.length >= 8;
      const hasUppercase = /[A-Z]/.test(password);
      const hasNumber = /[0-9]/.test(password);
      
      function setValid(el: HTMLElement | null, valid: boolean) {
        if (!el) return;
        const dot = el.querySelector('span:first-child');
        if (dot) {
          dot.className = `w-4 h-4 rounded-full flex items-center justify-center mr-2 text-[10px] ${valid ? 'bg-green-500 text-white' : 'bg-[var(--border-color)]'}`;
        }
        const text = el.querySelector('span:last-child');
        if (text) {
          text.className = valid ? 'text-green-400' : 'text-[var(--text-muted)]';
        }
      }
      
      setValid(reqLength, hasLength);
      setValid(reqUppercase, hasUppercase);
      setValid(reqNumber, hasNumber);
    }
    
    passwordInput?.addEventListener('input', (e) => {
      updatePasswordIndicators((e.target as HTMLInputElement).value);
    });
    
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const username = (document.getElementById('username') as HTMLInputElement).value;
      const password = passwordInput.value;
      const confirmPassword = confirmInput.value;
      const btn = document.getElementById('register-btn') as HTMLButtonElement;
      
      // Validation
      if (password !== confirmPassword) {
        errorDiv?.classList.remove('hidden');
        if (errorDiv) errorDiv.textContent = 'Passwords do not match';
        return;
      }
      
      if (password.length < 8) {
        errorDiv?.classList.remove('hidden');
        if (errorDiv) errorDiv.textContent = 'Password must be at least 8 characters';
        return;
      }
      
      btn.disabled = true;
      btn.textContent = 'Creating account...';
      
      try {
        const result = await register(email, password, username);
        
        if (result.success) {
          form.classList.add('hidden');
          successDiv?.classList.remove('hidden');
          
          // Redirect after delay
          setTimeout(() => {
            window.location.href = '/login?registered=true';
          }, 3000);
        } else {
          errorDiv?.classList.remove('hidden');
          if (errorDiv) errorDiv.textContent = result.error || 'Registration failed';
        }
      } catch (err) {
        errorDiv?.classList.remove('hidden');
        if (errorDiv) errorDiv.textContent = 'An error occurred. Please try again.';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Create Account';
      }
    });
  </script>
</Layout>