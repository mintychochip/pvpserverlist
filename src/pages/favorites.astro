---
// Favorites Page - Shows user's favorite servers
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="My Favorites | GuildPost"
  description="View and manage your favorite Minecraft servers on GuildPost."
  url="https://guildpost.tech/favorites"
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      <h1 class="text-4xl font-black text-white mb-4">My Favorites</h1>
      <p class="text-[#8892b0] text-lg mb-8">Your saved Minecraft servers for quick access.</p>

      <div id="favorites-list" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        <div class="col-span-full text-center py-12 text-[#8892b0]">Loading favorites...</div>
      </div>

      <!-- Export Button -->
      <div class="mb-6 flex justify-end">
        <button 
          id="export-favorites"
          class="px-4 py-2 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg transition-colors flex items-center gap-2 text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Export
        </button>
      </div>

      <div id="empty-state" class="hidden text-center py-12">
        <div class="w-16 h-16 bg-[#1a1a25] rounded-full flex items-center justify-center mx-auto mb-4">
          <span class="text-[#8892b0] text-3xl">♡</span>
        </div>
        <h2 class="text-xl font-bold text-white mb-2">No favorites yet</h2>
        <p class="text-[#8892b0] mb-4">Start browsing and add servers to your favorites!</p>
        <a href="/minecraft" class="inline-block px-6 py-3 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded-lg hover:bg-[#00d4b8] transition-colors">
          Browse Servers
        </a>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';
  
  const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
  const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndweHV0c2RiaWFtcG54ZmdrandxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNTEwMDQsImV4cCI6MjA5MDkyNzAwNH0.35hrTSgxQnICpLOY3g6W3eNxxe7DKCc3q165tyb0Ieo';
  
  const favoritesList = document.getElementById('favorites-list');
  const emptyState = document.getElementById('empty-state');
  
  // Get favorites from localStorage
  const favoriteIds = JSON.parse(localStorage.getItem('guildpost_favorites') || '[]');
  
  if (favoriteIds.length === 0) {
    favoritesList.innerHTML = '';
    emptyState.classList.remove('hidden');
  } else {
    loadFavorites();
  }
  
  async function loadFavorites() {
    const supabase = createClient(supabaseUrl, supabaseKey);
    
    const { data: servers, error } = await supabase
      .from('servers')
      .select('*')
      .in('id', favoriteIds);
    
    if (error) {
      favoritesList.innerHTML = '<div class="col-span-full text-center py-12 text-[#ff3864]">Error loading favorites</div>';
      return;
    }
    
    if (!servers || servers.length === 0) {
      favoritesList.innerHTML = '';
      emptyState.classList.remove('hidden');
      return;
    }
    
    emptyState.classList.add('hidden');
    
    favoritesList.innerHTML = servers.map(server => `
      <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg group relative">
        <button 
          class="remove-fav absolute top-2 right-2 p-2 text-[#ff3864] hover:bg-[#ff3864]/20 rounded-lg transition-colors"
          data-id="${server.id}"
        >
          ✕
        </button>
        
        <a href="/servers/${server.id}" class="block">
          <div class="flex items-start gap-3">
            <div class="w-12 h-12 bg-[#1a1a25] rounded-lg flex items-center justify-center">
              ${server.icon ? 
                `<img src="${server.icon}" alt="" class="w-full h-full object-cover rounded-lg">` : 
                `<span class="text-[#00f5d4] text-xl">⛏</span>`
              }
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-bold text-white group-hover:text-[#00f5d4] transition-colors truncate">${server.name}</h3>
              <p class="text-[#8892b0] text-sm truncate">${server.ip}:${server.port}</p>
              
              <div class="flex items-center gap-3 mt-2 text-xs">
                <span class="${server.status === 'online' ? 'text-green-500' : 'text-gray-500'}">
                  ${server.status === 'online' ? '● Online' : '○ Offline'}
                </span>
                <span class="text-[#8892b0]">
                  ${server.players_online || 0} players
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>
    `).join('');
    
    // Add remove handlers
    document.querySelectorAll('.remove-fav').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const id = btn.dataset.id;
        let favorites = JSON.parse(localStorage.getItem('guildpost_favorites') || '[]');
        favorites = favorites.filter(fid => fid !== id);
        localStorage.setItem('guildpost_favorites', JSON.stringify(favorites));
        
        // Remove from DOM
        btn.closest('.group').remove();
        
        // Check if empty
        if (favorites.length === 0) {
          favoritesList.innerHTML = '';
          emptyState.classList.remove('hidden');
        }
      });
    });
  }
  
  // Export favorites
  document.getElementById('export-favorites')?.addEventListener('click', async () => {
    const favoriteIds = JSON.parse(localStorage.getItem('guildpost_favorites') || '[]');
    if (favoriteIds.length === 0) {
      showToast('No favorites to export', 'warning');
      return;
    }
    
    const supabase = createClient(supabaseUrl, supabaseKey);
    const { data: servers } = await supabase
      .from('servers')
      .select('name, ip, port, website')
      .in('id', favoriteIds);
    
    if (!servers) {
      showToast('Failed to export', 'error');
      return;
    }
    
    // Export as CSV
    const csv = [
      ['Name', 'IP', 'Port', 'Website'].join(','),
      ...servers.map(s => [
        `"${s.name}"`,
        s.ip,
        s.port,
        s.website || ''
      ].join(','))
    ].join('\n');
    
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `guildpost-favorites-${new Date().toISOString().split('T')[0]}.csv`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    
    showToast(`Exported ${servers.length} favorites`, 'success');
  });
</script>
    <Footer />