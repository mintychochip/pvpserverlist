---
// Trending Servers Section - Shows popular servers from analytics
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndweHV0c2RiaWFtcG54ZmdrandxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNTEwMDQsImV4cCI6MjA5MDkyNzAwNH0.35hrTSgxQnICpLOY3g6W3eNxxe7DKCc3q165tyb0Ieo';

// Fetch trending + recently added
let trendingServers = [];
let recentServers = [];
let topRated = [];

try {
  // Trending (most votes in last 7 days)
  const trendingRes = await fetch(
    `${supabaseUrl}/rest/v1/servers?select=*&order=vote_count.desc&limit=6`,
    { headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }}
  );
  if (trendingRes.ok) trendingServers = await trendingRes.json();
  
  // Recently added
  const recentRes = await fetch(
    `${supabaseUrl}/rest/v1/servers?select=*&order=created_at.desc&limit=6`,
    { headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }}
  );
  if (recentRes.ok) recentServers = await recentRes.json();
  
  // Top rated
  const ratedRes = await fetch(
    `${supabaseUrl}/rest/v1/servers?select=*&rating_average=gte.4&order=rating_average.desc&limit=6`,
    { headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }}
  );
  if (ratedRes.ok) topRated = await ratedRes.json();
} catch (e) {
  console.error('Error fetching sections:', e);
}

const ServerCard = ({ server, badge }) => (
  <a href={`/servers/${server.id}`} class="block p-4 bg-[#12121a] border border-[#2a2a3a] hover:border-[#00f5d4] rounded-lg transition-all group relative overflow-hidden">
    {badge && (
      <span class="absolute top-2 right-2 px-2 py-1 bg-[#ff3864] text-white text-xs font-bold rounded">
        {badge}
      </span>
    )}
    <div class="flex items-start gap-3">
      <div class="w-12 h-12 bg-[#1a1a25] rounded-lg flex items-center justify-center">
        {server.icon ? (
          <img src={server.icon} alt="" class="w-full h-full object-cover rounded-lg" />
        ) : (
          <span class="text-[#00f5d4] text-xl">⛏</span>
        )}
      </div>
      <div class="flex-1 min-w-0">
        <h3 class="font-bold text-white group-hover:text-[#00f5d4] transition-colors truncate">{server.name}</h3>
        <p class="text-[#8892b0] text-sm truncate">{server.ip}:{server.port}</p>
        
        <div class="flex items-center gap-3 mt-2 text-xs">
          <span class={server.status === 'online' ? 'text-green-500' : 'text-gray-500'}>
            {server.status === 'online' ? '● Online' : '○ Offline'}
          </span>
          <span class="text-[#8892b0]">{server.players_online || 0} players</span>
          {server.rating_average && (
            <span class="text-yellow-500">★ {server.rating_average}</span>
          )}
        </div>
      </div>
    </div>
  </a>
);
---

<Layout 
  title="Discover Servers | GuildPost"
  description="Discover trending, new, and top-rated Minecraft servers on GuildPost."
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      <h1 class="text-4xl font-black text-white mb-2">Discover</h1>
      <p class="text-[#8892b0] mb-8">Find the perfect Minecraft server from our curated collections.</p>

      <!-- Trending Section -->
      <section class="mb-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-white flex items-center gap-2">
            <span class="text-[#ff3864]">🔥</span> Trending
          </h2>
          <a href="/minecraft?sort=votes" class="text-[#00f5d4] hover:underline text-sm">View All</a>
        </div>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {trendingServers.map((server, i) => (
            <ServerCard server={server} badge={i < 3 ? `#${i + 1}` : null} />
          ))}
        </div>
      </section>

      <!-- Recently Added -->
      <section class="mb-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-white flex items-center gap-2">
            <span class="text-[#00f5d4]">✨</span> Recently Added
          </h2>
          <a href="/minecraft?sort=newest" class="text-[#00f5d4] hover:underline text-sm">View All</a>
        </div>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {recentServers.map(server => (
            <ServerCard server={server} badge="New" />
          ))}
        </div>
      </section>

      <!-- Top Rated -->
      {topRated.length > 0 && (
        <section class="mb-12">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-bold text-white flex items-center gap-2">
              <span class="text-yellow-500">★</span> Top Rated
            </h2>
          </div>
          <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            {topRated.map(server => (
              <ServerCard server={server} />
            ))}
          </div>
        </section>
      )}

      <!-- Browse All CTA -->
      <div class="text-center py-8">
        <a href="/minecraft" class="inline-flex items-center gap-2 bg-[#00f5d4] text-[#0a0a0f] px-8 py-4 font-bold text-lg hover:bg-[#00d4b8] transition-colors rounded-lg">
          Browse All Servers
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </main>
    
    <Footer />
  </div>
</Layout>