---
// Server Search Wizard - AI-powered conversational search using Gemma 4B
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="AI Server Wizard | GuildPost"
  description="Let our AI find the perfect Minecraft server for you. Powered by Gemma 4B."
  url="https://guildpost.tech/wizard"
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-4xl mx-auto px-4 py-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00f5d4]/10 border border-[#00f5d4]/30 rounded-full text-[#00f5d4] text-sm mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
          Powered by Gemma 4B
        </div>
        <h1 class="text-4xl font-black text-white mb-4">🔮 AI Server Wizard</h1>
        <p class="text-[#8892b0] text-lg max-w-xl mx-auto">
          Tell me what you're looking for and I'll find the perfect Minecraft server for you.
        </p>
      </div>

      <!-- Chat Container -->
      <div class="bg-[#12121a] border border-[#2a2a3a] rounded-lg overflow-hidden">
        <!-- Messages -->
        <div id="chat-messages" class="p-6 space-y-4 min-h-[400px] max-h-[500px] overflow-y-auto">
          <!-- AI welcome message -->
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-full bg-[#00f5d4]/20 flex items-center justify-center flex-shrink-0">
              <span class="text-sm">🔮</span>
            </div>
            <div class="flex-1">
              <div class="bg-[#1a1a25] rounded-lg p-4 text-white">
                <p class="mb-3">Hi! I'm your AI server assistant. Tell me about the Minecraft server you're looking for.</p>
                <p class="text-[#8892b0] text-sm">For example: "I want a survival server with a friendly community and claims protection" or "hardcore pvp factions with economy"</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Input Area -->
        <div class="border-t border-[#2a2a3a] p-4">
          <div class="flex gap-3">
            <input 
              type="text" 
              id="chat-input"
              placeholder="Describe your ideal server..."
              class="flex-1 px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4]"
              autocomplete="off"
            />
            <button 
              id="send-btn"
              class="px-6 py-3 bg-[#00f5d4] text-[#0a0a0f] font-bold rounded-lg hover:bg-[#00d4b8] transition-colors flex items-center gap-2"
            >
              <span>Send</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m22 2-7 20-4-8-8-4Z"/>
                <path d="m22 2-11 11"/>
              </svg>
            </button>
          </div>
          <div class="flex gap-2 mt-3">
            <button class="quick-prompt px-3 py-1.5 bg-[#1a1a25] text-[#8892b0] rounded text-sm hover:bg-[#2a2a3a] transition-colors" data-prompt="survival server with active community">
              Survival + Community
            </button>
            <button class="quick-prompt px-3 py-1.5 bg-[#1a1a25] text-[#8892b0] rounded text-sm hover:bg-[#2a2a3a] transition-colors" data-prompt="hardcore pvp factions">
              Hardcore PvP
            </button>
            <button class="quick-prompt px-3 py-1.5 bg-[#1a1a25] text-[#8892b0] rounded text-sm hover:bg-[#2a2a3a] transition-colors" data-prompt="creative plot world with large builds">
              Creative Building
            </button>
            <button class="quick-prompt px-3 py-1.5 bg-[#1a1a25] text-[#8892b0] rounded text-sm hover:bg-[#2a2a3a] transition-colors" data-prompt="skyblock with economy and custom items">
              Skyblock Economy
            </button>
          </div>
        </div>
      </div>

      <!-- Results (hidden initially) -->
      <div id="results-container" class="hidden mt-8">
        <div class="text-center mb-6">
          <h2 class="text-2xl font-bold text-white mb-2">Recommended Servers</h2>
          <p class="text-[#8892b0]" id="results-summary"></p>
        </div>

        <div id="wizard-results" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 mb-8">
          <!-- Results populated by JS -->
        </div>

        <div class="text-center">
          <button id="restart-wizard" class="px-6 py-3 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg transition-colors">
            Start New Search
          </button>
        </div>
      </div>
    </main>
    
    <Footer />
  </div>
</Layout>

<script>
  const chatMessages = document.getElementById('chat-messages');
  const chatInput = document.getElementById('chat-input');
  const sendBtn = document.getElementById('send-btn');
  const resultsContainer = document.getElementById('results-container');
  
  let conversationHistory = [];
  let isSearching = false;
  
  // Add message to chat
  function addMessage(content, isUser = false) {
    const messageDiv = document.createElement('div');
    messageDiv.className = 'flex gap-3';
    
    if (isUser) {
      messageDiv.innerHTML = `
        <div class="flex-1 text-right">
          <div class="inline-block bg-[#00f5d4]/20 rounded-lg p-4 text-white text-left max-w-[80%]">
            ${content}
          </div>
        </div>
        <div class="w-8 h-8 rounded-full bg-[#ff3864]/20 flex items-center justify-center flex-shrink-0">
          <span class="text-sm">👤</span>
        </div>
      `;
    } else {
      messageDiv.innerHTML = `
        <div class="w-8 h-8 rounded-full bg-[#00f5d4]/20 flex items-center justify-center flex-shrink-0">
          <span class="text-sm">🔮</span>
        </div>
        <div class="flex-1">
          <div class="bg-[#1a1a25] rounded-lg p-4 text-white">
            ${content}
          </div>
        </div>
      `;
    }
    
    chatMessages.appendChild(messageDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }
  
  // Add loading indicator
  function addLoading() {
    const loadingDiv = document.createElement('div');
    loadingDiv.id = 'loading-message';
    loadingDiv.className = 'flex gap-3';
    loadingDiv.innerHTML = `
      <div class="w-8 h-8 rounded-full bg-[#00f5d4]/20 flex items-center justify-center flex-shrink-0">
        <span class="text-sm">🔮</span>
      </div>
      <div class="flex-1">
        <div class="bg-[#1a1a25] rounded-lg p-4 text-white">
          <div class="flex gap-1">
            <span class="w-2 h-2 bg-[#00f5d4] rounded-full animate-bounce" style="animation-delay: 0s"></span>
            <span class="w-2 h-2 bg-[#00f5d4] rounded-full animate-bounce" style="animation-delay: 0.1s"></span>
            <span class="w-2 h-2 bg-[#00f5d4] rounded-full animate-bounce" style="animation-delay: 0.2s"></span>
          </div>
        </div>
      </div>
    `;
    chatMessages.appendChild(loadingDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }
  
  function removeLoading() {
    document.getElementById('loading-message')?.remove();
  }
  
  // Quick prompts
  document.querySelectorAll('.quick-prompt').forEach(btn => {
    btn.addEventListener('click', () => {
      chatInput.value = btn.dataset.prompt;
      sendMessage();
    });
  });
  
  // Send message
  async function sendMessage() {
    const message = chatInput.value.trim();
    if (!message || isSearching) return;
    
    chatInput.value = '';
    addMessage(message, true);
    conversationHistory.push({ role: 'user', content: message });
    
    addLoading();
    isSearching = true;
    
    try {
      // Call semantic search API with conversation context
      const response = await fetch('/api/search/semantic', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query: message,
          conversation: conversationHistory.slice(-6), // Last 3 exchanges
          limit: 6
        })
      });
      
      if (!response.ok) {
        throw new Error('Search failed');
      }
      
      const data = await response.json();
      
      removeLoading();
      
      if (data.results && data.results.length > 0) {
        // Show results
        showResults(data.results, message);
        addMessage(`I found ${data.results.length} servers that match what you're looking for! Check them out below. Want to refine your search? Tell me more details.`, false);
      } else {
        addMessage(`I couldn't find any servers matching "${message}". Try describing what you want differently - for example, mention game modes like survival, pvp, skyblock, or features like economy, claims, or community size.`, false);
      }
      
      conversationHistory.push({ role: 'assistant', content: `Found ${data.results?.length || 0} results` });
      
    } catch (err) {
      console.error('Search error:', err);
      removeLoading();
      addMessage(`I'm having trouble connecting to the search service right now. Please try again in a moment, or <a href="/minecraft" class="text-[#00f5d4] underline">browse all servers</a> directly.`, false);
    }
    
    isSearching = false;
  }
  
  // Show results
  function showResults(servers, query) {
    resultsContainer.classList.remove('hidden');
    document.getElementById('results-summary').textContent = `Based on "${query}"`;
    
    const resultsDiv = document.getElementById('wizard-results');
    resultsDiv.innerHTML = servers.map(server => `
      <a href="/servers/${server.id}" class="block p-4 bg-[#12121a] border border-[#2a2a3a] hover:border-[#00f5d4] rounded-lg transition-all group">
        <div class="flex items-start gap-3">
          <div class="w-12 h-12 bg-[#1a1a25] rounded-lg flex items-center justify-center flex-shrink-0">
            ${server.icon ? 
              `<img src="${server.icon}" alt="" class="w-full h-full object-cover rounded-lg">` : 
              `<span class="text-[#00f5d4] text-xl">⛏</span>`
            }
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-bold text-white group-hover:text-[#00f5d4] transition-colors truncate">${server.name || 'Unnamed Server'}</h3>
            <p class="text-[#8892b0] text-sm truncate">${server.ip}:${server.port}</p>
            
            <div class="flex items-center gap-3 mt-2 text-xs">
              <span class="${server.status === 'online' ? 'text-green-500' : 'text-gray-500'}">
                ${server.status === 'online' ? '● Online' : '○ Offline'}
              </span>
              <span class="text-[#8892b0]">${server.players_online || 0} players</span>
              <span class="text-[#ff3864]">▲ ${server.vote_count || 0}</span>
            </div>
            
            ${server.tags?.length ? `
              <div class="flex flex-wrap gap-1 mt-2">
                ${server.tags.slice(0, 3).map(tag => `
                  <span class="px-2 py-0.5 bg-[#1a1a25] text-[#8892b0] rounded text-xs">${tag}</span>
                `).join('')}
              </div>
            ` : ''}
          </div>
        </div>
      </a>
    `).join('');
    
    // Scroll to results
    resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  
  // Event listeners
  sendBtn?.addEventListener('click', sendMessage);
  chatInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') sendMessage();
  });
  
  // Restart
  document.getElementById('restart-wizard')?.addEventListener('click', () => {
    conversationHistory = [];
    resultsContainer.classList.add('hidden');
    chatMessages.innerHTML = `
      <div class="flex gap-3">
        <div class="w-8 h-8 rounded-full bg-[#00f5d4]/20 flex items-center justify-center flex-shrink-0">
          <span class="text-sm">🔮</span>
        </div>
        <div class="flex-1">
          <div class="bg-[#1a1a25] rounded-lg p-4 text-white">
            <p class="mb-3">Hi! I'm your AI server assistant. Tell me about the Minecraft server you're looking for.</p>
            <p class="text-[#8892b0] text-sm">For example: "I want a survival server with a friendly community" or "hardcore pvp factions with economy"</p>
          </div>
        </div>
      </div>
    `;
    chatInput.focus();
  });
</script>
