---
// Server Detail Page - Server-side rendered with Cloudflare
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Reviews from '../../components/Reviews.astro';

const { id } = Astro.params;

// Server-side fetch from Supabase
const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndweHV0c2RiaWFtcG54ZmdrandxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNTEwMDQsImV4cCI6MjA5MDkyNzAwNH0.35hrTSgxQnICpLOY3g6W3eNxxe7DKCc3q165tyb0Ieo';

let server = null;
let relatedServers = [];
let reviews = [];
let uptimeStats = null;
let staffMembers = [];
let posts = [];
let error = null;

try {
  // Fetch main server
  const response = await fetch(`${supabaseUrl}/rest/v1/servers?id=eq.${id}&select=*`, {
    headers: {
      'apikey': supabaseKey,
      'Authorization': `Bearer ${supabaseKey}`
    }
  });
  
  if (response.ok) {
    const data = await response.json();
    server = data[0] || null;
    
    if (server) {
      // Fetch related servers (same tags)
      if (server.tags && server.tags.length > 0) {
        const tag = server.tags[0];
        const relatedResponse = await fetch(
          `${supabaseUrl}/rest/v1/servers?tags=cs.{${tag}}&id=neq.${id}&limit=4&select=*`,
          { headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }}
        );
        if (relatedResponse.ok) {
          relatedServers = await relatedResponse.json();
        }
      }
      
      // Fetch reviews
      const reviewsRes = await fetch(
        `${supabaseUrl}/rest/v1/server_reviews?server_id=eq.${id}&is_approved=eq.true&order=created_at.desc&limit=5`,
        { headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }}
      );
      if (reviewsRes.ok) {
        reviews = await reviewsRes.json();
      }
      
      // Fetch uptime stats
      const uptimeRes = await fetch(
        `${supabaseUrl}/rest/v1/server_uptime_stats?server_id=eq.${id}`,
        { headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }}
      );
      if (uptimeRes.ok) {
        const uptimeData = await uptimeRes.json();
        uptimeStats = uptimeData[0] || null;
      }
      
      // Fetch staff members
      const staffRes = await fetch(
        `${supabaseUrl}/rest/v1/staff_members?server_id=eq.${id}&is_active=eq.true&order=sort_order.asc,role.asc`,
        { headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }}
      );
      if (staffRes.ok) {
        staffMembers = await staffRes.json();
      }
      
      // Fetch blog posts
      const postsRes = await fetch(
        `${supabaseUrl}/rest/v1/server_posts?server_id=eq.${id}&is_published=eq.true&order=is_pinned.desc,published_at.desc&limit=10`,
        { headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }}
      );
      if (postsRes.ok) {
        posts = await postsRes.json();
      }
    }
  } else {
    error = 'Failed to fetch server';
  }
} catch (e) {
  error = e.message;
}

// If no server found, return 404
if (!server) {
  return new Response('Server not found', { status: 404 });
}

const isOnline = server.status === 'online';
---

<Layout 
  title={`${server.name} | GuildPost`}
  description={server.description || `Join ${server.name} Minecraft server. ${server.players_online || 0} players online, ${server.vote_count || 0} votes. View server details, vote, and connect.`}
  url={`https://guildpost.tech/servers/${id}`}
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-6xl mx-auto px-4 py-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-[#8892b0] mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/minecraft" class="hover:text-white transition-colors">Minecraft</a>
        <span>/</span>
        <span class="text-white">{server.name}</span>
      </nav>

      <!-- Banner -->
      {server.banner && (
        <div class="mb-6 rounded-lg overflow-hidden border border-[#2a2a3a]">
          <img src={server.banner} alt={`${server.name} banner`} class="w-full h-48 md:h-64 object-cover" />
        </div>
      )}
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Server Header -->
          <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-16 h-16 bg-[#1a1a25] rounded-lg flex items-center justify-center overflow-hidden">
                {server.icon ? (
                  <img src={server.icon} alt="" class="w-full h-full object-cover" />
                ) : (
                  <span class="text-[#00f5d4] text-2xl">⛏</span>
                )}
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <h1 class="text-2xl font-bold text-white">{server.name}</h1>
                  {server.verified && (
                    <span class="px-2 py-1 bg-[#00f5d4]/20 text-[#00f5d4] text-xs font-bold rounded">
                      ✓ VERIFIED
                    </span>
                  )}
                </div>
                <code class="text-[#8892b0]">{server.ip}:{server.port}</code>
              </div>
            </div>
            
            {server.description && (
              <p class="text-[#8892b0] leading-relaxed">{server.description}</p>
            )}

            <!-- Tags -->
            {server.tags && server.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-4">
                {server.tags.map(tag => (
                  <a 
                    href={`/minecraft/${tag.toLowerCase()}`}
                    class="px-3 py-1 bg-[#1a1a25] hover:bg-[#00f5d4]/20 hover:text-[#00f5d4] text-[#8892b0] rounded-lg text-sm transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            )}
          </div>
          
          <!-- Stats Grid -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg text-center">
              <p class="text-2xl font-bold text-[#00f5d4]">{server.players_online || 0}</p>
              <p class="text-xs text-[#8892b0]">Players Online</p>
            </div>
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg text-center">
              <p class="text-2xl font-bold text-white">{server.max_players || '?'}</p>
              <p class="text-xs text-[#8892b0]">Max Players</p>
            </div>
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg text-center">
              <p class="text-2xl font-bold text-[#ff3864]">{server.vote_count || 0}</p>
              <p class="text-xs text-[#8892b0]">Total Votes</p>
            </div>
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg text-center">
              <p class="text-2xl font-bold {isOnline ? 'text-green-500' : 'text-gray-500'}">
                {isOnline ? '●' : '○'}
              </p>
              <p class="text-xs text-[#8892b0]">{isOnline ? 'Online' : 'Offline'}</p>
            </div>
          </div>

          <!-- Staff/Team Section -->
          {staffMembers.length > 0 && (
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg" id="staff-section">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                  <span>👥</span> Staff Team
                  <span class="text-sm font-normal text-[#8892b0]">({staffMembers.length})</span>
                </h2>
              </div>
              
              {/* Group staff by role */}
              {['owner', 'admin', 'developer', 'moderator', 'helper', 'builder', 'content_creator'].map(role => {
                const roleStaff = staffMembers.filter((s) => s.role === role);
                if (roleStaff.length === 0) return null;
                
                const roleLabels = {
                  owner: 'Owner',
                  admin: 'Admin',
                  developer: 'Developer',
                  moderator: 'Moderator',
                  helper: 'Helper',
                  builder: 'Builder',
                  content_creator: 'Content Creator'
                };
                
                const roleColors = {
                  owner: '#ff3864',
                  admin: '#ff6b6b',
                  developer: '#00f5d4',
                  moderator: '#ffd93d',
                  helper: '#6bcf7f',
                  builder: '#a78bfa',
                  content_creator: '#f472b6'
                };
                
                return (
                  <div class="mb-4 last:mb-0">
                    <h3 class="text-sm font-bold uppercase tracking-wider mb-3" style={`color: ${roleColors[role]}`}>
                      {roleLabels[role]}
                    </h3>
                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
                      {roleStaff.map((member: any) => (
                        <div class="group relative bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg p-3 hover:border-[#00f5d4] transition-all cursor-pointer"
                             data-staff-username={member.minecraft_username}>
                          <div class="flex flex-col items-center text-center">
                            <div class="w-14 h-14 mb-2 relative">
                              <img 
                                src={`https://mc-heads.net/avatar/${encodeURIComponent(member.minecraft_username)}/64`}
                                alt={member.minecraft_username}
                                class="w-full h-full rounded-lg pixelated"
                                loading="lazy"
                                onerror="this.src='https://mc-heads.net/avatar/Steve/64'"
                              />
                              <div class="absolute -bottom-1 -right-1 w-5 h-5 rounded-full flex items-center justify-center text-xs" style={`background-color: ${roleColors[role]}20`}>
                                <span style={`color: ${roleColors[role]}`}>{role === 'owner' ? '👑' : role === 'admin' ? '⚔️' : role === 'developer' ? '💻' : role === 'moderator' ? '🛡️' : role === 'helper' ? '🤝' : role === 'builder' ? '🏗️' : '🎬'}</span>
                              </div>
                            </div>
                            <p class="font-bold text-white text-sm truncate max-w-full">
                              {member.display_name || member.minecraft_username}
                            </p>
                            {member.bio && (
                              <p class="text-[#8892b0] text-xs mt-1 line-clamp-2">{member.bio}</p>
                            )}
                          </div>
                          
                          {/* Hover tooltip */}
                          <div class="absolute inset-0 bg-[#0a0a0f]/95 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center p-2 pointer-events-none">
                            <p class="font-bold text-white text-sm">{member.minecraft_username}</p>
                            {member.discord_username && (
                              <p class="text-[#00f5d4] text-xs mt-1">Discord: {member.discord_username}</p>
                            )}
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          )}

          <!-- Voting Section -->
          <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
            <h2 class="text-xl font-bold text-white mb-4">Vote for {server.name}</h2>
            <div class="space-y-3">
              <input 
                type="text" 
                id="voter-username" 
                placeholder="Your Minecraft username" 
                class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4]"
              >
              <button 
                id="vote-btn"
                class="w-full px-4 py-3 bg-[#ff3864] hover:bg-[#e63357] text-white font-bold rounded-lg transition-colors flex items-center justify-center gap-2"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
                Vote Now
              </button>
              <p id="vote-message" class="text-sm hidden"></p>
            </div>
          </div>

          <!-- Server Analytics -->
          <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg" id="analytics-section">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-xl font-bold text-white">📊 Server Analytics</h2>
              <div class="flex gap-2">
                <button class="analytics-tab px-3 py-1 text-xs rounded bg-[#00f5d4] text-[#0a0a0f] font-bold" data-period="24h">24h</button>
                <button class="analytics-tab px-3 py-1 text-xs rounded bg-[#1a1a25] text-[#8892b0]" data-period="7d">7d</button>
                <button class="analytics-tab px-3 py-1 text-xs rounded bg-[#1a1a25] text-[#8892b0]" data-period="30d">30d</button>
              </div>
            </div>
            
            <!-- Analytics Grid -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
              <div class="p-3 bg-[#0a0a0f] rounded-lg text-center">
                <p class="text-lg font-bold text-[#00f5d4]" id="avg-players">-</p>
                <p class="text-xs text-[#8892b0]">Avg Players</p>
              </div>
              <div class="p-3 bg-[#0a0a0f] rounded-lg text-center">
                <p class="text-lg font-bold text-white" id="peak-players">{server.players_online || 0}</p>
                <p class="text-xs text-[#8892b0]">Peak (Current)</p>
              </div>
              <div class="p-3 bg-[#0a0a0f] rounded-lg text-center">
                <p class="text-lg font-bold text-[#ff3864]" id="vote-trend">+{server.vote_count || 0}</p>
                <p class="text-xs text-[#8892b0]">Total Votes</p>
              </div>
              <div class="p-3 bg-[#0a0a0f] rounded-lg text-center">
                <p class="text-lg font-bold text-green-500" id="uptime-stat">
                  {uptimeStats ? `${uptimeStats.uptime_percentage}%` : 'N/A'}
                </p>
                <p class="text-xs text-[#8892b0]">Uptime</p>
              </div>
            </div>
            
            <!-- Player Count Chart -->
            <div class="mb-4">
              <h3 class="text-sm font-bold text-[#8892b0] mb-2">Player Count History</h3>
              <div class="h-40 bg-[#0a0a0f] rounded-lg p-3 relative overflow-hidden">
                <canvas id="player-chart" class="w-full h-full"></canvas>
                <div id="chart-loading" class="absolute inset-0 flex items-center justify-center text-[#8892b0] text-sm">
                  Loading data...
                </div>
              </div>
            </div>
            
            <!-- Additional Stats -->
            <div class="grid grid-cols-3 gap-4 text-center text-sm">
              <div>
                <p class="text-[#8892b0]">Rank</p>
                <p class="font-bold text-white" id="server-rank">#{server.rank || 'N/A'}</p>
              </div>
              <div>
                <p class="text-[#8892b0]">Trending</p>
                <p class="font-bold text-[#00f5d4]">{server.trending_score > 0 ? '↗ Up' : '→ Stable'}</p>
              </div>
              <div>
                <p class="text-[#8892b0]">Listed Since</p>
                <p class="font-bold text-white">{new Date(server.created_at).toLocaleDateString()}</p>
              </div>
            </div>
            
            <p class="text-[#8892b0] text-xs mt-4 text-center">
              📈 <a href={`/api/servers/${id}/uptime`} class="text-[#00f5d4] hover:underline" target="_blank">View Full Uptime Data</a>
              • <a href={`/stats?server=${id}`} class="text-[#00f5d4] hover:underline">Global Stats</a>
            </p>
          </div>

          <!-- Server Blog/News Section -->
          {posts.length > 0 && (
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                  <span>📰</span> Server News
                  <span class="text-sm font-normal text-[#8892b0]">({posts.length})</span>
                </h2>
                <a href={`/blog?server=${id}`} class="text-sm text-[#00f5d4] hover:underline">
                  View All →
                </a>
              </div>
              
              <div class="space-y-4">
                {posts.slice(0, 5).map(post => {
                  const categoryLabels = {
                    news: { emoji: '📰', label: 'News' },
                    update: { emoji: '🔄', label: 'Update' },
                    patch: { emoji: '📦', label: 'Patch' },
                    event: { emoji: '🎉', label: 'Event' },
                    announcement: { emoji: '📢', label: 'Announce' },
                    other: { emoji: '📝', label: 'Post' }
                  };
                  const cat = categoryLabels[post.category] || categoryLabels.other;
                  const date = new Date(post.published_at);
                  const formattedDate = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                  
                  // Strip HTML for summary
                  const summary = post.summary || post.content?.replace(/<[^>]*>/g, ' ').substring(0, 150) + '...' || '';
                  
                  return (
                    <div class={`p-4 bg-[#0a0a0f] rounded-lg border ${post.is_pinned ? 'border-[#ff3864]/50' : 'border-[#2a2a3a]'} hover:border-[#00f5d4]/50 transition-colors`}>
                      <div class="flex items-start gap-3">
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-2 mb-1 flex-wrap">
                            {post.is_pinned && (
                              <span class="px-2 py-0.5 bg-[#ff3864]/20 text-[#ff3864] text-xs font-bold rounded">
                                📌 PINNED
                              </span>
                            )}
                            <span class="text-xs text-[#8892b0]">
                              {cat.emoji} {cat.label}
                            </span>
                            <span class="text-xs text-[#8892b0]">•</span>
                            <span class="text-xs text-[#8892b0]">{formattedDate}</span>
                            <span class="text-xs text-[#8892b0]">•</span>
                            <span class="text-xs text-[#8892b0]">👁 {post.view_count || 0}</span>
                          </div>
                          <h3 class="font-bold text-white mb-1 hover:text-[#00f5d4] transition-colors cursor-pointer" onclick={`showPostModal('${post.id}', '${post.title.replace(/'/g, "\\'")}', '${post.content.replace(/'/g, "\\'")}', '${post.author}', '${post.category}', '${post.published_at}')`}>
                            {post.title}
                          </h3>
                          <p class="text-[#8892b0] text-sm line-clamp-2">{summary}</p>
                          <p class="text-[#8892b0] text-xs mt-2">By {post.author}</p>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
              
              {posts.length > 5 && (
                <div class="mt-4 text-center">
                  <a href={`/blog?server=${id}`} class="inline-block px-4 py-2 bg-[#1a1a25] hover:bg-[#2a2a3a] text-[#8892b0] rounded-lg text-sm transition-colors">
                    View {posts.length - 5} more posts →
                  </a>
                </div>
              )}
            </div>
          )}

          <!-- Related Servers -->
          {relatedServers.length > 0 && (
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <h2 class="text-xl font-bold text-white mb-4">Similar Servers</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {relatedServers.map(related => (
                  <a 
                    href={`/servers/${related.id}`}
                    class="flex items-center gap-3 p-3 bg-[#0a0a0f] hover:bg-[#1a1a25] rounded-lg transition-colors"
                  >
                    <div class="w-10 h-10 bg-[#1a1a25] rounded-lg flex items-center justify-center">
                      {related.icon ? (
                        <img src={related.icon} alt="" class="w-full h-full object-cover rounded-lg" />
                      ) : (
                        <span class="text-[#00f5d4]">⛏</span>
                      )}
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-bold text-white truncate">{related.name}</p>
                      <p class="text-xs text-[#8892b0]">{related.players_online || 0} players • {related.vote_count || 0} votes</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
        
        <!-- Sidebar -->
        <div class="space-y-4">
          <!-- Quick Actions -->
          <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
            <h3 class="font-bold text-white mb-3">Quick Actions</h3>
            
            <a 
              href={`minecraft://${server.ip}:${server.port}`}
              class="block w-full p-3 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold text-center rounded-lg transition-colors mb-2"
            >
              Join Server
            </a>
            
            <button 
              id="copy-ip-btn"
              class="block w-full p-3 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg transition-colors mb-2"
            >
              Copy IP Address
            </button>
            
            <button 
              id="favorite-btn"
              class="block w-full p-3 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg transition-colors flex items-center justify-center gap-2"
            >
              <span id="favorite-icon">♡</span>
              <span id="favorite-text">Add to Favorites</span>
            </button>
          </div>

          <!-- Uptime Stats -->
          {uptimeStats && uptimeStats.uptime_percentage && (
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <h3 class="font-bold text-white mb-3">Uptime (24h)</h3>
              <div class="flex items-center gap-3">
                <div class="flex-1">
                  <div class="flex justify-between text-sm mb-1">
                    <span class="text-[#8892b0]">Reliability</span>
                    <span class="text-green-500 font-bold">{uptimeStats.uptime_percentage}%</span>
                  </div>
                  <div class="h-2 bg-[#1a1a25] rounded-full overflow-hidden">
                    <div 
                      class="h-full bg-gradient-to-r from-green-500 to-[#00f5d4] rounded-full"
                      style={`width: ${uptimeStats.uptime_percentage}%`}
                    />
                  </div>
                </div>
              </div>
              <p class="text-[#8892b0] text-xs mt-2">
                Online for {uptimeStats.online_checks} of {uptimeStats.total_checks} checks
              </p>
            </div>
          )}

          <!-- Ratings -->
          {server.rating_count > 0 && (
            <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
              <h3 class="font-bold text-white mb-2">Rating</h3>
              <div class="flex items-center gap-2">
                <span class="text-3xl font-bold text-yellow-500">{server.rating_average}</span>
                <div>
                  <div class="text-yellow-500 text-lg">
                    {'★'.repeat(Math.round(server.rating_average))}
                    {'☆'.repeat(5 - Math.round(server.rating_average))}
                  </div>
                  <p class="text-[#8892b0] text-xs">{server.rating_count} reviews</p>
                </div>
              </div>
            </div>
          )}

          <!-- Server Info -->
          <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
            <h3 class="font-bold text-white mb-3">Server Information</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-[#8892b0]">Version</span>
                <span class="text-white">{server.version || 'Any'}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-[#8892b0]">Status</span>
                <span class={isOnline ? 'text-green-500' : 'text-gray-500'}>
                  {isOnline ? '● Online' : '○ Offline'}
                </span>
              </div>
              <div class="flex justify-between">
                <span class="text-[#8892b0]">Added</span>
                <span class="text-white">{new Date(server.created_at).toLocaleDateString()}</span>
              </div>
              {server.website && (
                <div class="pt-2 border-t border-[#2a2a3a]">
                  <a href={server.website} target="_blank" class="text-[#00f5d4] hover:underline flex items-center gap-1">
                    Visit Website
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                </div>
              )}
            </div>
          </div>

          <!-- Share -->
          <div class="p-4 bg-[#12121a] border border-[#2a2a3a] rounded-lg">
            <h3 class="font-bold text-white mb-3">Share</h3>
            <div class="flex gap-2">
              <button id="share-twitter" class="flex-1 py-2 bg-black hover:bg-gray-900 text-white rounded-lg text-sm transition-colors flex items-center justify-center gap-2 border border-gray-800">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                X
              </button>
              <button id="share-discord" class="flex-1 py-2 bg-[#5865F2] hover:bg-[#4752c4] text-white rounded-lg text-sm transition-colors flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                </svg>
                Discord
              </button>
              <button id="share-copy" class="flex-1 py-2 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg text-sm transition-colors flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                Copy
              </button>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Gallery Section -->
      <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-lg" id="gallery-section">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold text-white flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            Gallery
          </h2>
          <span id="gallery-count" class="text-[#8892b0] text-sm">Loading...</span>
        </div>
        
        <div id="gallery-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          <div class="col-span-full text-center py-8">
            <div class="animate-spin w-6 h-6 border-2 border-[#00f5d4] border-t-transparent rounded-full mx-auto"></div>
            <p class="text-[#8892b0] text-sm mt-2">Loading screenshots...</p>
          </div>
        </div>
        
        <p class="text-[#8892b0] text-xs mt-4 text-center">
          Screenshots showcase this server's world, builds, and events
        </p>
      </div>

      <!-- Reviews Section -->
      <Reviews serverId={id} reviews={reviews} />
    </main>
  </div>
</Layout>

<script define:vars={{ serverId: id, serverIp: server.ip, serverPort: server.port, serverName: server.name }}>
  // Copy IP functionality
  document.getElementById('copy-ip-btn')?.addEventListener('click', async () => {
    const ip = `${serverIp}:${serverPort}`;
    await navigator.clipboard.writeText(ip);
    const btn = document.getElementById('copy-ip-btn');
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy IP Address', 2000);
  });

  // Favorite functionality
  const favoriteBtn = document.getElementById('favorite-btn');
  const favoriteIcon = document.getElementById('favorite-icon');
  const favoriteText = document.getElementById('favorite-text');
  
  // Check if favorited
  const favorites = JSON.parse(localStorage.getItem('guildpost_favorites') || '[]');
  let isFavorited = favorites.includes(serverId);
  
  function updateFavoriteUI() {
    if (isFavorited) {
      favoriteIcon.textContent = '♥';
      favoriteText.textContent = 'Favorited';
      favoriteBtn.classList.add('text-[#ff3864]');
    } else {
      favoriteIcon.textContent = '♡';
      favoriteText.textContent = 'Add to Favorites';
      favoriteBtn.classList.remove('text-[#ff3864]');
    }
  }
  
  updateFavoriteUI();
  
  favoriteBtn?.addEventListener('click', () => {
    let favorites = JSON.parse(localStorage.getItem('guildpost_favorites') || '[]');
    if (isFavorited) {
      favorites = favorites.filter(id => id !== serverId);
    } else {
      favorites.push(serverId);
    }
    localStorage.setItem('guildpost_favorites', JSON.stringify(favorites));
    isFavorited = !isFavorited;
    updateFavoriteUI();
  });

  // Share functionality
  const shareUrl = window.location.href;
  const shareText = `Check out ${serverName} on GuildPost!`;
  
  document.getElementById('share-twitter')?.addEventListener('click', () => {
    window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`, '_blank');
  });
  
  document.getElementById('share-discord')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(`${shareText} ${shareUrl}`);
    alert('Copied to clipboard! Paste in Discord.');
  });
  
  document.getElementById('share-copy')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(shareUrl);
    const btn = document.getElementById('share-copy');
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy Link', 2000);
  });

  // Voting functionality
  const voteBtn = document.getElementById('vote-btn');
  const voterUsername = document.getElementById('voter-username');
  const voteMessage = document.getElementById('vote-message');
  
  voteBtn?.addEventListener('click', async () => {
    const username = voterUsername.value.trim();
    
    if (!username) {
      voteMessage.textContent = 'Please enter your Minecraft username';
      voteMessage.className = 'text-sm text-[#ff3864]';
      voteMessage.classList.remove('hidden');
      return;
    }
    
    if (!/^[a-zA-Z0-9_]{3,16}$/.test(username)) {
      voteMessage.textContent = 'Invalid username (3-16 chars, letters/numbers/underscores)';
      voteMessage.className = 'text-sm text-[#ff3864]';
      voteMessage.classList.remove('hidden');
      return;
    }
    
    // Check if already voted in last 24h
    const lastVote = localStorage.getItem(`vote_${serverId}_${username.toLowerCase()}`);
    if (lastVote) {
      const hoursSince = (Date.now() - parseInt(lastVote)) / (1000 * 60 * 60);
      if (hoursSince < 24) {
        const hoursLeft = Math.ceil(24 - hoursSince);
        voteMessage.textContent = `You already voted! Wait ${hoursLeft} more hours.`;
        voteMessage.className = 'text-sm text-yellow-500';
        voteMessage.classList.remove('hidden');
        return;
      }
    }
    
    voteBtn.disabled = true;
    voteBtn.innerHTML = '<span class="animate-spin">↻</span> Voting...';
    
    try {
      const response = await fetch('https://wpxutsdbiampnxfgkjwq.supabase.co/functions/v1/vote', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ serverId, username, address: serverIp })
      });
      
      const result = await response.json();
      
      if (response.ok && result.success) {
        localStorage.setItem(`vote_${serverId}_${username.toLowerCase()}`, Date.now().toString());
        voteMessage.textContent = 'Vote recorded! Thank you.';
        voteMessage.className = 'text-sm text-green-500';
        voteBtn.innerHTML = '✓ Voted';
        setTimeout(() => location.reload(), 1500);
      } else {
        voteMessage.textContent = result.message || 'Failed to vote';
        voteMessage.className = 'text-sm text-[#ff3864]';
        voteBtn.disabled = false;
        voteBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg> Vote Now`;
      }
    } catch (err) {
      voteMessage.textContent = 'Error: ' + err.message;
      voteMessage.className = 'text-sm text-[#ff3864]';
      voteBtn.disabled = false;
      voteBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg> Vote Now`;
    }
    
    voteMessage.classList.remove('hidden');
  });
  
  // Analytics functionality
  const analyticsTabs = document.querySelectorAll('.analytics-tab');
  const canvas = document.getElementById('player-chart');
  const loadingEl = document.getElementById('chart-loading');
  let currentPeriod = '24h';
  
  // Tab switching
  analyticsTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      analyticsTabs.forEach(t => {
        t.classList.remove('bg-[#00f5d4]', 'text-[#0a0a0f]');
        t.classList.add('bg-[#1a1a25]', 'text-[#8892b0]');
      });
      tab.classList.remove('bg-[#1a1a25]', 'text-[#8892b0]');
      tab.classList.add('bg-[#00f5d4]', 'text-[#0a0a0f]');
      currentPeriod = tab.dataset.period;
      loadAnalytics(currentPeriod);
    });
  });
  
  // Load analytics data
  async function loadAnalytics(period = '24h') {
    if (loadingEl) loadingEl.style.display = 'flex';
    
    try {
      // Fetch ping history from uptime API
      const days = period === '24h' ? 1 : period === '7d' ? 7 : 30;
      const response = await fetch(`/api/servers/${serverId}/uptime?days=${days}`);
      const data = await response.json();
      
      if (data.raw_data && data.raw_data.length > 0) {
        drawChart(data.raw_data, period);
        updateStats(data, period);
      } else if (data.chart_data && data.chart_data.length > 0) {
        // Use daily aggregated data for chart
        drawDailyChart(data.chart_data);
        updateStats(data, period);
      } else {
        // Fallback: show "no data" state
        if (canvas) {
          const ctx = canvas.getContext('2d');
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.fillStyle = '#8892b0';
          ctx.font = '14px sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText('No ping data yet - check back soon!', canvas.width / 2, canvas.height / 2);
        }
        // Show current server stats
        document.getElementById('avg-players').textContent = '0';
        document.getElementById('uptime-stat').textContent = 'N/A';
      }
    } catch (err) {
      console.error('Analytics load error:', err);
      // Show error state
      if (canvas) {
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = '#ff3864';
        ctx.font = '12px sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText('Error loading analytics', canvas.width / 2, canvas.height / 2);
      }
    } finally {
      if (loadingEl) loadingEl.style.display = 'none';
    }
  }
  
  // Draw chart from daily aggregated data
  function drawDailyChart(chartData) {
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d');
    const width = canvas.width = canvas.offsetWidth * 2;
    const height = canvas.height = canvas.offsetHeight * 2;
    ctx.scale(2, 2);
    
    const displayWidth = width / 2;
    const displayHeight = height / 2;
    
    ctx.clearRect(0, 0, displayWidth, displayHeight);
    
    if (chartData.length < 2) {
      ctx.fillStyle = '#8892b0';
      ctx.font = '14px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('Not enough data yet', displayWidth / 2, displayHeight / 2);
      return;
    }
    
    // Get player values
    const players = chartData.map(d => d.avg_players || 0);
    const maxPlayers = Math.max(...players, 1);
    const minPlayers = Math.min(...players, 0);
    const range = maxPlayers - minPlayers || 1;
    
    // Draw gradient fill
    const gradient = ctx.createLinearGradient(0, 0, 0, displayHeight);
    gradient.addColorStop(0, 'rgba(0, 245, 212, 0.3)');
    gradient.addColorStop(1, 'rgba(0, 245, 212, 0)');
    
    ctx.beginPath();
    ctx.moveTo(0, displayHeight);
    
    chartData.forEach((d, i) => {
      const x = (i / (chartData.length - 1)) * displayWidth;
      const y = displayHeight - ((d.avg_players - minPlayers) / range) * (displayHeight * 0.7) - 20;
      ctx.lineTo(x, y);
    });
    
    ctx.lineTo(displayWidth, displayHeight);
    ctx.closePath();
    ctx.fillStyle = gradient;
    ctx.fill();
    
    // Draw line
    ctx.beginPath();
    ctx.strokeStyle = '#00f5d4';
    ctx.lineWidth = 2;
    
    chartData.forEach((d, i) => {
      const x = (i / (chartData.length - 1)) * displayWidth;
      const y = displayHeight - ((d.avg_players - minPlayers) / range) * (displayHeight * 0.7) - 20;
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    
    ctx.stroke();
    
    // Labels
    ctx.fillStyle = '#8892b0';
    ctx.font = '10px sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText(`${maxPlayers} avg players`, 5, 15);
    ctx.textAlign = 'right';
    ctx.fillText(`${minPlayers} avg players`, displayWidth - 5, displayHeight - 5);
  }
  
  // Generate mock history for demo
  function generateMockHistory(period) {
    const points = period === '24h' ? 24 : period === '7d' ? 28 : 30;
    const history = [];
    const basePlayers = server.players_online || 50;
    
    for (let i = 0; i < points; i++) {
      const variation = Math.sin(i * 0.5) * (basePlayers * 0.3) + (Math.random() - 0.5) * 10;
      history.push({
        timestamp: new Date(Date.now() - (points - i) * (period === '24h' ? 3600000 : period === '7d' ? 21600000 : 86400000)).toISOString(),
        players_online: Math.max(0, Math.round(basePlayers + variation))
      });
    }
    return history;
  }
  
  // Draw simple sparkline chart
  function drawChart(history, period) {
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d');
    const width = canvas.width = canvas.offsetWidth * 2; // HiDPI
    const height = canvas.height = canvas.offsetHeight * 2;
    ctx.scale(2, 2);
    
    const displayWidth = width / 2;
    const displayHeight = height / 2;
    
    ctx.clearRect(0, 0, displayWidth, displayHeight);
    
    if (history.length < 2) return;
    
    // Get data points
    const players = history.map(h => h.players_online || 0);
    const maxPlayers = Math.max(...players, 1);
    const minPlayers = Math.min(...players, 0);
    const range = maxPlayers - minPlayers || 1;
    
    // Draw gradient fill
    const gradient = ctx.createLinearGradient(0, 0, 0, displayHeight);
    gradient.addColorStop(0, 'rgba(0, 245, 212, 0.3)');
    gradient.addColorStop(1, 'rgba(0, 245, 212, 0)');
    
    ctx.beginPath();
    ctx.moveTo(0, displayHeight);
    
    players.forEach((val, i) => {
      const x = (i / (players.length - 1)) * displayWidth;
      const y = displayHeight - ((val - minPlayers) / range) * (displayHeight * 0.8) - 10;
      ctx.lineTo(x, y);
    });
    
    ctx.lineTo(displayWidth, displayHeight);
    ctx.closePath();
    ctx.fillStyle = gradient;
    ctx.fill();
    
    // Draw line
    ctx.beginPath();
    ctx.strokeStyle = '#00f5d4';
    ctx.lineWidth = 2;
    
    players.forEach((val, i) => {
      const x = (i / (players.length - 1)) * displayWidth;
      const y = displayHeight - ((val - minPlayers) / range) * (displayHeight * 0.8) - 10;
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    
    ctx.stroke();
    
    // Draw points
    ctx.fillStyle = '#00f5d4';
    players.forEach((val, i) => {
      if (i % Math.ceil(players.length / 8) === 0 || i === players.length - 1) {
        const x = (i / (players.length - 1)) * displayWidth;
        const y = displayHeight - ((val - minPlayers) / range) * (displayHeight * 0.8) - 10;
        ctx.beginPath();
        ctx.arc(x, y, 3, 0, Math.PI * 2);
        ctx.fill();
      }
    });
    
    // Labels
    ctx.fillStyle = '#8892b0';
    ctx.font = '10px sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText(`${maxPlayers} players`, 5, 15);
    ctx.textAlign = 'right';
    ctx.fillText(`${minPlayers} players`, displayWidth - 5, displayHeight - 5);
  }
  
  // Update stats display from API data
  function updateStats(data, period) {
    const avgEl = document.getElementById('avg-players');
    const peakEl = document.getElementById('peak-players');
    const uptimeEl = document.getElementById('uptime-stat');
    
    // Use averages from API response
    if (avgEl && data.averages && data.averages.players_online !== undefined) {
      avgEl.textContent = data.averages.players_online;
    } else if (avgEl && data.raw_data && data.raw_data.length > 0) {
      // Calculate from raw data
      const avg = data.raw_data.reduce((sum, h) => sum + (h.players_online || 0), 0) / data.raw_data.length;
      avgEl.textContent = Math.round(avg);
    }
    
    // Peak players from current server data (passed from Astro)
    if (peakEl) {
      peakEl.textContent = server.players_online || 0;
    }
    
    // Uptime percentage from API
    if (uptimeEl && data.uptime && data.uptime.percentage !== undefined) {
      uptimeEl.textContent = `${data.uptime.percentage}%`;
      // Color based on uptime
      if (data.uptime.percentage >= 95) {
        uptimeEl.className = 'text-lg font-bold text-green-500';
      } else if (data.uptime.percentage >= 80) {
        uptimeEl.className = 'text-lg font-bold text-yellow-500';
      } else {
        uptimeEl.className = 'text-lg font-bold text-[#ff3864]';
      }
    }
  }
  
  // Load initial analytics
  loadAnalytics('24h');
  
  // Load gallery screenshots
  loadGallery();
  
  async function loadGallery() {
    const grid = document.getElementById('gallery-grid');
    const countEl = document.getElementById('gallery-count');
    
    if (!grid) return;
    
    try {
      const response = await fetch(`/api/servers/${serverId}/screenshots`);
      const data = await response.json();
      
      if (!response.ok) {
        throw new Error(data.error || 'Failed to load gallery');
      }
      
      const screenshots = data.screenshots || [];
      
      if (screenshots.length === 0) {
        grid.innerHTML = `
          <div class="col-span-full text-center py-8">
            <div class="w-12 h-12 bg-[#1a1a25] rounded-full flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#8892b0" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
            <p class="text-[#8892b0] text-sm">No screenshots yet</p>
            <p class="text-[#8892b0] text-xs mt-1">Server owner can upload screenshots in their dashboard</p>
          </div>
        `;
        if (countEl) countEl.textContent = '0 screenshots';
        return;
      }
      
      if (countEl) countEl.textContent = `${screenshots.length} screenshot${screenshots.length !== 1 ? 's' : ''}`;
      
      grid.innerHTML = screenshots.map((screenshot: any, index: number) => `
        <div class="gallery-item relative aspect-video rounded-lg overflow-hidden cursor-pointer border border-[#2a2a3a] hover:border-[#00f5d4] transition-all group"
             onclick="openLightbox(${index})"
             data-index="${index}">
          <img src="${screenshot.url}" 
               alt="${screenshot.caption || 'Server screenshot'}" 
               class="w-full h-full object-cover transition-transform group-hover:scale-105"
               loading="lazy">
          ${screenshot.caption ? `
            <div class="absolute bottom-0 left-0 right-0 p-2 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
              <p class="text-white text-xs truncate">${screenshot.caption}</p>
            </div>
          ` : ''}
        </div>
      `).join('');
      
      // Store screenshots for lightbox
      (window as any).galleryScreenshots = screenshots;
      
    } catch (err) {
      console.error('Gallery load error:', err);
      grid.innerHTML = `
        <div class="col-span-full text-center py-8">
          <p class="text-[#8892b0] text-sm">Failed to load gallery</p>
        </div>
      `;
    }
  }
  
  // Lightbox functionality
  let currentLightboxIndex = 0;
  
  (window as any).openLightbox = function(index: number) {
    const screenshots = (window as any).galleryScreenshots || [];
    if (!screenshots.length) return;
    
    currentLightboxIndex = index;
    const screenshot = screenshots[index];
    
    // Create lightbox if it doesn't exist
    let lightbox = document.getElementById('gallery-lightbox');
    if (!lightbox) {
      lightbox = document.createElement('div');
      lightbox.id = 'gallery-lightbox';
      lightbox.className = 'fixed inset-0 bg-black/95 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300';
      lightbox.innerHTML = `
        <button onclick="closeLightbox()" class="absolute top-4 right-4 p-2 text-white hover:text-[#00f5d4] z-50">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <button onclick="prevScreenshot()" class="absolute left-4 p-2 text-white hover:text-[#00f5d4] z-50 hidden md:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button onclick="nextScreenshot()" class="absolute right-4 p-2 text-white hover:text-[#00f5d4] z-50 hidden md:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
        <div class="max-w-5xl max-h-[80vh] mx-auto px-4 flex flex-col items-center">
          <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[70vh] object-contain rounded-lg shadow-2xl">
          <p id="lightbox-caption" class="text-white text-center mt-4 px-4 max-w-2xl"></p>
          <p id="lightbox-counter" class="text-[#8892b0] text-sm mt-2"></p>
        </div>
        <div id="lightbox-thumbnails" class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 max-w-[90vw] overflow-x-auto px-4"></div>
      `;
      document.body.appendChild(lightbox);
      
      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        if (lightbox?.classList.contains('opacity-100')) {
          if (e.key === 'Escape') (window as any).closeLightbox();
          if (e.key === 'ArrowLeft') (window as any).prevScreenshot();
          if (e.key === 'ArrowRight') (window as any).nextScreenshot();
        }
      });
      
      // Touch/swipe support
      let touchStartX = 0;
      lightbox.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });
      
      lightbox.addEventListener('touchend', (e) => {
        const touchEndX = e.changedTouches[0].clientX;
        const diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) (window as any).nextScreenshot();
          else (window as any).prevScreenshot();
        }
      }, { passive: true });
    }
    
    updateLightboxContent();
    lightbox.classList.remove('opacity-0', 'pointer-events-none');
    lightbox.classList.add('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = 'hidden';
  };
  
  (window as any).closeLightbox = function() {
    const lightbox = document.getElementById('gallery-lightbox');
    if (lightbox) {
      lightbox.classList.add('opacity-0', 'pointer-events-none');
      lightbox.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    }
  };
  
  (window as any).prevScreenshot = function() {
    const screenshots = (window as any).galleryScreenshots || [];
    currentLightboxIndex = (currentLightboxIndex - 1 + screenshots.length) % screenshots.length;
    updateLightboxContent();
  };
  
  (window as any).nextScreenshot = function() {
    const screenshots = (window as any).galleryScreenshots || [];
    currentLightboxIndex = (currentLightboxIndex + 1) % screenshots.length;
    updateLightboxContent();
  };
  
  function updateLightboxContent() {
    const screenshots = (window as any).galleryScreenshots || [];
    const screenshot = screenshots[currentLightboxIndex];
    
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const caption = document.getElementById('lightbox-caption');
    const counter = document.getElementById('lightbox-counter');
    const thumbnails = document.getElementById('lightbox-thumbnails');
    
    if (img) {
      img.style.opacity = '0';
      setTimeout(() => {
        img.src = screenshot.url;
        img.alt = screenshot.caption || 'Server screenshot';
        img.onload = () => { img.style.opacity = '1'; };
      }, 150);
    }
    
    if (caption) {
      caption.textContent = screenshot.caption || '';
      caption.style.display = screenshot.caption ? 'block' : 'none';
    }
    
    if (counter) {
      counter.textContent = `${currentLightboxIndex + 1} / ${screenshots.length}`;
    }
    
    if (thumbnails && screenshots.length > 1) {
      thumbnails.innerHTML = screenshots.map((s: any, i: number) => `
        <button onclick="jumpToScreenshot(${i})" 
                class="w-16 h-12 rounded overflow-hidden border-2 transition-colors flex-shrink-0 ${i === currentLightboxIndex ? 'border-[#00f5d4]' : 'border-transparent hover:border-[#8892b0]'}"
                aria-label="Go to image ${i + 1}">
          <img src="${s.url}" class="w-full h-full object-cover" alt="">
        </button>
      `).join('');
    }
  }
  
  (window as any).jumpToScreenshot = function(index: number) {
    currentLightboxIndex = index;
    updateLightboxContent();
  };
  
  // Post Modal functionality
  (window as any).showPostModal = function(postId: string, title: string, content: string, author: string, category: string, publishedAt: string) {
    // Create modal if it doesn't exist
    let modal = document.getElementById('post-modal');
    if (!modal) {
      modal = document.createElement('div');
      modal.id = 'post-modal';
      modal.className = 'fixed inset-0 bg-black/80 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 p-4';
      modal.innerHTML = `
        <div class="bg-[#12121a] border border-[#2a2a3a] rounded-lg max-w-2xl w-full max-h-[80vh] overflow-hidden flex flex-col">
          <div class="p-4 border-b border-[#2a2a3a] flex items-center justify-between">
            <h3 id="post-modal-title" class="text-xl font-bold text-white"></h3>
            <button onclick="closePostModal()" class="text-[#8892b0] hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
          <div class="p-4 overflow-y-auto flex-1">
            <div class="flex items-center gap-2 mb-4 text-sm text-[#8892b0]">
              <span id="post-modal-category"></span>
              <span>•</span>
              <span id="post-modal-date"></span>
              <span>•</span>
              <span>By <span id="post-modal-author"></span></span>
            </div>
            <div id="post-modal-content" class="prose prose-invert prose-sm max-w-none"></div>
          </div>
        </div>
      `;
      document.body.appendChild(modal);
      
      // Close on backdrop click
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closePostModal();
      });
      
      // Close on escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closePostModal();
      });
    }
    
    // Update content
    const titleEl = document.getElementById('post-modal-title');
    const contentEl = document.getElementById('post-modal-content');
    const authorEl = document.getElementById('post-modal-author');
    const categoryEl = document.getElementById('post-modal-category');
    const dateEl = document.getElementById('post-modal-date');
    
    if (titleEl) titleEl.textContent = title;
    if (contentEl) contentEl.innerHTML = content;
    if (authorEl) authorEl.textContent = author;
    if (dateEl) dateEl.textContent = new Date(publishedAt).toLocaleDateString();
    
    const catLabels = {
      news: '📰 News',
      update: '🔄 Update',
      patch: '📦 Patch',
      event: '🎉 Event',
      announcement: '📢 Announce',
      other: '📝 Post'
    };
    if (categoryEl) categoryEl.textContent = catLabels[category] || catLabels.other;
    
    // Show modal
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.classList.add('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = 'hidden';
    
    // Track view (async, don't wait)
    fetch(`/api/servers/${serverId}/posts?view=${postId}`, { method: 'POST' }).catch(() => {});
  };
  
  (window as any).closePostModal = function() {
    const modal = document.getElementById('post-modal');
    if (modal) {
      modal.classList.add('opacity-0', 'pointer-events-none');
      modal.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    }
  };
</script>

