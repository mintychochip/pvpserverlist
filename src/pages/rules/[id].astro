---
// Server Rules Page - Public page displaying server rules with markdown formatting
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import MarkdownRenderer from '../../components/MarkdownRenderer.astro';

export async function getStaticPaths() {
  // Server-rendered - return empty paths, will be generated on demand
  return [];
}

const { id: serverId } = Astro.params;

const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndweHV0c2RiaWFtcG54ZmdrandxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNTEwMDQsImV4cCI6MjA5MDkyNzAwNH0.35hrTSgxQnICpLOY3g6W3eNxxe7DKCc3q165tyb0Ieo';

let server = null;
let rules = null;
let error = null;
let hasRules = false;

try {
  // Fetch server details
  const serverRes = await fetch(`${supabaseUrl}/rest/v1/servers?id=eq.${serverId}&select=*`, {
    headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }
  });
  
  if (serverRes.ok) {
    const servers = await serverRes.json();
    server = servers[0] || null;
  }

  // Fetch rules
  const rulesRes = await fetch(`${supabaseUrl}/rest/v1/server_rules?server_id=eq.${serverId}&select=*`, {
    headers: { 'apikey': supabaseKey, 'Authorization': `Bearer ${supabaseKey}` }
  });
  
  if (rulesRes.ok) {
    const rulesData = await rulesRes.json();
    if (rulesData.length > 0) {
      rules = rulesData[0];
      hasRules = true;
    }
  }
} catch (e) {
  error = e.message;
}

// If server doesn't exist, return 404
if (!server) {
  return new Response('Server not found', { status: 404 });
}

const pageTitle = hasRules ? `${server.name} - Server Rules | GuildPost` : `${server.name} - Rules | GuildPost`;
const pageDescription = hasRules 
  ? `Rules and guidelines for ${server.name} Minecraft server. Read before joining.`
  : `Server rules for ${server.name}. Contact the server owner for more information.`;
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  url={`https://guildpost.tech/rules/${serverId}`}
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />
    
    <main class="max-w-4xl mx-auto px-4 py-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-[#8892b0] mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/minecraft" class="hover:text-white transition-colors">Minecraft</a>
        <span>/</span>
        <a href={`/servers/${serverId}`} class="hover:text-white transition-colors">{server.name}</a>
        <span>/</span>
        <span class="text-white">Rules</span>
      </nav>

      <!-- Header Section -->
      <div class="mb-8">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-16 h-16 bg-[#12121a] border border-[#2a2a3a] rounded-lg flex items-center justify-center overflow-hidden">
            {server.icon ? (
              <img src={server.icon} alt="" class="w-full h-full object-cover" />
            ) : (
              <span class="text-[#00f5d4] text-2xl">⛏</span>
            )}
          </div>
          <div>
            <h1 class="text-3xl font-bold text-white">{server.name}</h1>
            <p class="text-[#8892b0]">Server Rules & Guidelines</p>
          </div>
        </div>
      </div>

      {hasRules ? (
        <!-- Rules Content -->
        <div class="bg-[#12121a] border border-[#2a2a3a] rounded-lg p-6 md:p-8">
          <div class="flex items-center justify-between mb-6 pb-4 border-b border-[#2a2a3a]">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-[#00f5d4]/10 rounded-lg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00f5d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-white">Rules & Guidelines</h2>
                <p class="text-xs text-[#8892b0]">
                  Last updated: {new Date(rules.updated_at).toLocaleDateString('en-US', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                  })}
                </p>
              </div>
            </div>
            
            <a 
              href={`/servers/${serverId}`}
              class="hidden sm:flex items-center gap-2 px-4 py-2 bg-[#1a1a25] hover:bg-[#2a2a3a] text-[#8892b0] rounded-lg transition-colors text-sm"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
              </svg>
              Back to Server
            </a>
          </div>

          <!-- Markdown Content -->
          <MarkdownRenderer content={rules.content} />
        </div>
      ) : (
        <!-- No Rules Set -->
        <div class="bg-[#12121a] border border-[#2a2a3a] rounded-lg p-12 text-center">
          <div class="w-20 h-20 bg-[#1a1a25] rounded-full flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#8892b0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
          </div>
          <h2 class="text-xl font-bold text-white mb-2">No Rules Set</h2>
          <p class="text-[#8892b0] mb-6 max-w-md mx-auto">
            This server hasn't published any rules yet. Check the server page for more information, or contact the server owner directly.
          </p>
          <a 
            href={`/servers/${serverId}`}
            class="inline-flex items-center gap-2 px-6 py-3 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            View Server Page
          </a>
        </div>
      )}

      <!-- Quick Actions -->
      <div class="mt-8 flex flex-wrap gap-4 justify-center">
        <a 
          href={`minecraft://${server.ip}:${server.port}`}
          class="px-6 py-3 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors"
        >
          Join Server
        </a>
        <button 
          id="copy-ip-btn"
          class="px-6 py-3 bg-[#1a1a25] hover:bg-[#2a2a3a] text-white rounded-lg transition-colors"
        >
          Copy IP: {server.ip}:{server.port}
        </button>
      </div>

      <!-- Disclaimer -->
      <div class="mt-12 p-4 bg-[#1a1a25]/50 border border-[#2a2a3a] rounded-lg">
        <p class="text-sm text-[#8892b0] text-center">
          <span class="text-[#00f5d4]">Note:</span> These rules are set by the server owner. 
          GuildPost is not responsible for enforcing them. Please report any issues directly to the server staff.
        </p>
      </div>
    </main>
  </div>
</Layout>

<script define:vars={{ serverIp: server.ip, serverPort: server.port }}>
  // Copy IP functionality
  document.getElementById('copy-ip-btn')?.addEventListener('click', async () => {
    const ip = `${serverIp}:${serverPort}`;
    await navigator.clipboard.writeText(ip);
    const btn = document.getElementById('copy-ip-btn');
    const originalText = btn.textContent;
    btn.textContent = 'Copied!';
    btn.classList.add('bg-green-500/20', 'text-green-500');
    setTimeout(() => {
      btn.textContent = originalText;
      btn.classList.remove('bg-green-500/20', 'text-green-500');
    }, 2000);
  });
</script>
