---
// GuildPost Astro - Main Homepage v2.0
// Modern gaming-focused design with electric accents

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AnimatedStat from '../components/AnimatedStat.astro';
import GemmaWizard from '../components/GemmaWizard.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

// Fetch real server count from Supabase
const supabaseUrl = import.meta.env.SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL || 'https://wpxutsdbiampnxfgkjwq.supabase.co';
const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

let serverCount = 9911; // Fallback to known count

try {
  if (supabaseUrl && supabaseKey) {
    const response = await fetch(
      `${supabaseUrl}/rest/v1/servers?select=count`,
      {
        headers: {
          'apikey': supabaseKey,
          'Authorization': `Bearer ${supabaseKey}`
        }
      }
    );
    
    if (response.ok) {
      const data = await response.json();
      if (data && data[0] && typeof data[0].count === 'number') {
        serverCount = data[0].count;
      }
    }
  }
} catch (e) {
  console.error('Failed to fetch server count:', e);
}

// Game categories data
const gameCategories = [
  {
    id: "minecraft",
    name: "Minecraft",
    description: "Survival, SMP, Skyblock, Factions & more",
    serverCount: serverCount,
    href: "/minecraft",
    featured: true,
  },
  {
    id: "rust",
    name: "Rust",
    description: "Coming soon",
    serverCount: 0,
    href: "#",
    featured: false,
  },
  {
    id: "cs2",
    name: "CS2",
    description: "Coming soon",
    serverCount: 0,
    href: "#",
    featured: false,
  },
];
---

<Layout 
  title="GuildPost - Discover Game Servers | Minecraft, Rust & More"
  description="Discover the best multiplayer game servers on GuildPost. Browse thousands of Minecraft servers across all game modes. Find your next multiplayer home."
  url="https://guildpost.tech"
  keywords="minecraft servers, minecraft multiplayer, game servers, survival servers, skyblock, factions, smp, rust servers, cs2 servers, server discovery, multiplayer games"
>
  <!-- Schema.org Structured Data for Homepage -->
  <SchemaOrg 
    type="WebSite" 
    data={{
      name: "GuildPost - Discover Game Servers",
      description: "The modern directory for game servers. From Minecraft to Rust, discover communities that match your play style.",
      url: "https://guildpost.tech",
      potentialAction: {
        "@type": "SearchAction",
        target: "https://guildpost.tech/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }} 
  />
  <SchemaOrg 
    type="Organization" 
    data={{
      name: "GuildPost",
      url: "https://guildpost.tech",
      logo: "https://guildpost.tech/logo-icon-512.png",
      sameAs: [
        "https://discord.gg/guildpost"
      ],
      description: "Game server discovery platform for Minecraft, Rust, CS2 and more multiplayer games."
    }} 
  />
  <SchemaOrg 
    type="ItemList" 
    data={{
      items: gameCategories.map(game => ({
        name: game.name,
        url: `https://guildpost.tech${game.href}`,
        playersOnline: game.serverCount
      }))
    }} 
  />

  <div class="min-h-screen" style="background-color: var(--bg-primary);">
    <Header />

    <!-- Hero Section - Modern Gaming Aesthetic -->
    <section class="relative px-4 pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gradient-radial from-[rgba(0,217,255,0.15)] to-transparent rounded-full blur-3xl"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-gradient-radial from-[rgba(255,0,110,0.1)] to-transparent rounded-full blur-3xl"></div>
      </div>

      <div class="max-w-4xl mx-auto text-center relative z-10">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 border" 
             style="background: rgba(0,217,255,0.1); border-color: rgba(0,217,255,0.3); color: var(--accent-primary);">
          <span class="w-2 h-2 rounded-full bg-[var(--accent-primary)] animate-pulse"></span>
          <span class="text-sm font-medium">{serverCount.toLocaleString()}+ Servers Available</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
          <span style="color: var(--text-primary);">Find your next</span><br />
          <span class="text-transparent bg-clip-text" style="background-image: var(--gradient-primary); -webkit-text-stroke: 1px rgba(255,255,255,0.1);">multiplayer home</span>
        </h1>
        <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10" style="color: var(--text-secondary);">
          The modern directory for game servers. From Minecraft to Rust, discover communities that match your play style.
        </p>

        <!-- Animated Stats -->
        <div 
          class="flex justify-center gap-8 md:gap-12 mb-10 py-5 px-8 max-w-xl mx-auto"
          style="background: rgba(30,41,59,0.5); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); backdrop-filter: blur(10px);"
        >
          <AnimatedStat value={serverCount} label="Servers" color="var(--accent-primary)" />
          <AnimatedStat value={50} suffix="+" label="Game Modes" color="var(--accent-secondary)" />
          <AnimatedStat value={0} label="Fake Reviews" color="var(--accent-tertiary)" />
        </div>

        <!-- Gemma AI Wizard -->
        <div class="max-w-3xl mx-auto mt-6 mb-4">
          <div class="flex items-center justify-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span class="text-sm font-medium" style="color: var(--text-secondary);">Powered by Gemini AI</span>
          </div>
          <GemmaWizard id="hero-wizard" />
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap justify-center gap-3 mt-8">
          <a
            href="/minecraft"
            class="gp-btn-primary inline-flex items-center gap-2 px-6 py-3 text-base"
            style="background: var(--gradient-primary); border: none; color: white; box-shadow: var(--shadow-glow);"
          >
            Browse Servers
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/wizard"
            class="gp-btn-outline inline-flex items-center gap-2 px-6 py-3 text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            AI Wizard
          </a>
          <a
            href="/submit"
            class="gp-btn-ghost inline-flex items-center gap-2 px-6 py-3 text-base"
          >
            Add Server
          </a>
        </div>
        
        <!-- Surprise Me Button -->
        <div class="mt-6">
          <button
            id="surprise-btn"
            class="inline-flex items-center gap-2 text-sm transition-colors hover:underline"
            style="color: var(--text-tertiary);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            Surprise me — Random Server
          </button>
        </div>
      </div>
    </section>

    <!-- Game Categories -->
    <section class="px-4 py-16 border-t" style="border-color: var(--border-subtle);">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl font-semibold mb-8 text-center" style="color: var(--text-primary);">
          Browse by Game
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {gameCategories.map((game) => (
            <a
              href={game.href}
              class={`group p-6 transition-all border ${
                game.featured
                  ? "hover:border-[var(--accent-primary)] hover:shadow-glow"
                  : "opacity-50 hover:opacity-80"
              }`}
              style={`background: rgba(30,41,59,0.3); border-radius: var(--radius-lg); border-color: var(--border-subtle);`}
            >
              <div class="mb-4" style={`color: ${game.featured ? 'var(--accent-primary)' : 'var(--text-secondary)'}`}>
                {game.id === 'minecraft' && (
                  <svg width="40" height="40" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M24 0L48 12L24 24L0 12L24 0Z" fill="#5D8C3A"/>
                    <path d="M24 24L48 12V36L24 48V24Z" fill="#735037"/>
                    <path d="M24 24L0 12V36L24 48V24Z" fill="#8B654D"/>
                    <path d="M0 12L24 24L48 12L24 0L0 12Z" fill="#5D8C3A"/>
                    <path d="M24 2L44 12L24 22L4 12L24 2Z" fill="#6B9E47"/>
                  </svg>
                )}
                {game.id === 'rust' && (
                  <svg width="40" height="40" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="24" cy="24" r="12" stroke="currentColor" stroke-width="2.5" fill="none"/>
                    <circle cx="24" cy="24" r="6" stroke="currentColor" stroke-width="2" fill="none"/>
                    <path d="M24 4V10" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    <path d="M24 38V44" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    <path d="M4 24H10" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    <path d="M38 24H44" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                  </svg>
                )}
                {game.id === 'cs2' && (
                  <svg width="40" height="40" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2.5" fill="none"/>
                    <path d="M24 10V24L34 30" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    <circle cx="24" cy="24" r="4" fill="currentColor"/>
                  </svg>
                )}
              </div>
              <h3 class="text-xl font-semibold mb-1" style="color: var(--text-primary);">{game.name}</h3>
              <p class="text-sm mb-3" style="color: var(--text-secondary);">{game.description}</p>
              {game.serverCount > 0 && (
                <p class="text-sm font-medium" style="color: var(--accent-primary);">{game.serverCount.toLocaleString()} servers</p>
              )}
              {game.featured && (
                <div class="mt-3 flex items-center gap-1 text-sm" style="color: var(--accent-primary);">
                  <span>Explore</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Minecraft Servers -->
    <section class="px-4 py-16 border-t" style="border-color: var(--border-subtle);">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-semibold" style="color: var(--text-primary);">Featured Minecraft Servers</h2>
          <a href="/minecraft" class="flex items-center gap-1 text-sm hover:underline" style="color: var(--accent-primary);">
            View all
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div id="featured-servers" class="grid gap-3 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          <div class="col-span-full text-center py-12" style="color: var(--text-secondary);">Loading servers...</div>
        </div>
      </div>
    </section>

    <!-- Why GuildPost -->
    <section class="px-4 py-16 border-t" style="border-color: var(--border-subtle);">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl font-semibold mb-10 text-center" style="color: var(--text-primary);">Why GuildPost?</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="text-center p-6" style="background: rgba(30,41,59,0.3); border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);">
            <div class="w-12 h-12 flex items-center justify-center mx-auto mb-4 text-xl rounded-lg" style="background: rgba(0,217,255,0.1); color: var(--accent-primary);">🎮</div>
            <h3 class="text-lg font-semibold mb-2" style="color: var(--text-primary);">Multi-Game Support</h3>
            <p class="text-sm" style="color: var(--text-secondary);">Starting with Minecraft, expanding to Rust, CS2, and more.</p>
          </div>
          <div class="text-center p-6" style="background: rgba(30,41,59,0.3); border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);">
            <div class="w-12 h-12 flex items-center justify-center mx-auto mb-4 text-xl rounded-lg" style="background: rgba(255,0,110,0.1); color: var(--accent-secondary);">👥</div>
            <h3 class="text-lg font-semibold mb-2" style="color: var(--text-primary);">Community Driven</h3>
            <p class="text-sm" style="color: var(--text-secondary);">Real player votes and reviews. No pay-to-win placement.</p>
          </div>
          <div class="text-center p-6" style="background: rgba(30,41,59,0.3); border-radius: var(--radius-lg); border: 1px solid var(--border-subtle);">
            <div class="w-12 h-12 flex items-center justify-center mx-auto mb-4 text-xl rounded-lg" style="background: rgba(131,56,236,0.1); color: var(--accent-tertiary);">📊</div>
            <h3 class="text-lg font-semibold mb-2" style="color: var(--text-primary);">Live Status</h3>
            <p class="text-sm" style="color: var(--text-secondary);">Real-time player counts and latency. Know before you join.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer CTA -->
    <section class="px-4 py-16 border-t" style="border-color: var(--border-subtle);">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl font-semibold mb-3" style="color: var(--text-primary);">Ready to find your server?</h2>
        <p class="mb-6" style="color: var(--text-secondary);">Join thousands of players discovering their next favorite multiplayer experience.</p>
        <a href="/minecraft" class="gp-btn-primary inline-flex items-center gap-2 px-6 py-3" 
           style="background: var(--gradient-primary); border: none; color: white; box-shadow: var(--shadow-glow);">
          Start Browsing
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<script>
  // Load featured servers from API
  async function loadServers() {
    try {
      const response = await fetch('/api/servers?limit=6');
      if (!response.ok) throw new Error('Failed to load servers');
      const data = await response.json();
      // Handle both {servers: [...]} and flat array responses
      const servers = Array.isArray(data) ? data : (data.servers || []);
      
      const container = document.getElementById('featured-servers');
      if (!servers.length) {
        container.innerHTML = `<div class="col-span-full text-center py-12" style="color: var(--text-secondary);">No servers found.</div>`;
        return;
      }
      
      container.innerHTML = servers.slice(0, 6).map(server => `
      <a href="/servers/${server.id}" class="block p-4 transition-all group gp-card-interactive" 
         style="background: rgba(30,41,59,0.3); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg);">
        <div class="flex items-start gap-3 mb-3">
          ${server.icon ? `<img src="${server.icon}" alt="${server.name} Minecraft server icon logo" class="w-12 h-12 rounded-lg" style="background-color: var(--bg-tertiary);" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" /><div class="w-12 h-12 rounded-lg items-center justify-center hidden" style="background-color: var(--bg-tertiary);"><span style="color: var(--accent-primary);" class="text-xl">⛏</span></div>` : `<div class="w-12 h-12 rounded-lg flex items-center justify-center" style="background-color: var(--bg-tertiary);"><span style="color: var(--accent-primary);" class="text-xl">⛏</span></div>`}
          <div class="flex-1 min-w-0">
            <h3 class="font-medium truncate text-base group-hover:text-[var(--accent-primary)] transition-colors" style="color: var(--text-primary);">${server.name}</h3>
            <p class="text-xs font-mono truncate" style="color: var(--text-tertiary);">${server.ip}:${server.port}</p>
          </div>
        </div>
        <div class="flex items-center gap-3 mb-2 text-xs">
          <span class="flex items-center gap-1" style="color: ${server.status === 'online' ? 'var(--success)' : 'var(--text-muted)'};">
            <span class="w-1.5 h-1.5 rounded-full" style="background-color: ${server.status === 'online' ? 'var(--success)' : 'var(--text-muted)'}"></span>
            ${server.players_online || 0}/${server.max_players || '?'}
          </span>
          <span class="flex items-center gap-1" style="color: var(--accent-secondary);">▲ ${server.vote_count || 0}</span>
        </div>
        <div class="flex flex-wrap gap-1">
          ${(server.tags || []).slice(0, 3).map(tag => `<span class="text-xs px-2 py-0.5 rounded" style="background-color: rgba(30,41,59,0.5); color: var(--text-secondary); border-radius: var(--radius-sm);">${tag}</span>`).join('')}
        </div>
      </a>
    `).join('');
    } catch (err) {
      console.error('Failed to load servers:', err);
      document.getElementById('featured-servers').innerHTML = '<div class="col-span-full text-center py-12" style="color: var(--text-secondary);">Failed to load servers.</div>';
    }
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadServers);
  } else {
    loadServers();
  }
  
  // Surprise Me
  document.getElementById('surprise-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('surprise-btn');
    btn.innerHTML = `<svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg> Finding...`;
    
    try {
      const response = await fetch('/api/servers');
      if (!response.ok) throw new Error('Failed to load servers');
      const data = await response.json();
      // Handle both {servers: [...]} and flat array responses
      const servers = Array.isArray(data) ? data : (data.servers || []);
      
      if (!servers.length) {
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg> Surprise me — Random Server`;
        return;
      }
      
      const randomServer = servers[Math.floor(Math.random() * servers.length)];
      window.location.href = `/servers/${randomServer.id}`;
    } catch (err) {
      console.error('Surprise me failed:', err);
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg> Surprise me — Random Server`;
    }
  });
  
</script>

<style>
  .bg-gradient-radial {
    background: radial-gradient(circle, var(--tw-gradient-stops));
  }
</style>
