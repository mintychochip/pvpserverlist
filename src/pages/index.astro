---
// GuildPost Astro - Main Homepage
// Static site with client-side Supabase data fetching

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import AnimatedStat from '../components/AnimatedStat.astro';

// Inline Arrow SVG component
const ArrowIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`;

// Game categories data
const gameCategories = [
  {
    id: "minecraft",
    name: "Minecraft",
    description: "PvP, Survival, Skyblock, Factions & more",
    iconColor: "#00f5d4",
    serverCount: 1037,
    href: "/minecraft",
    featured: true,
  },
  {
    id: "rust",
    name: "Rust",
    description: "Coming soon",
    iconColor: "#ff3864",
    serverCount: 0,
    href: "#",
    featured: false,
  },
  {
    id: "cs2",
    name: "CS2",
    description: "Coming soon",
    iconColor: "#9d4edd",
    serverCount: 0,
    href: "#",
    featured: false,
  },
];
---

<Layout 
  title="GuildPost - Find Your Server | Minecraft, Rust, CS2 Server List"
  description="Discover the best game servers on GuildPost. Browse 2,000+ Minecraft servers including PvP, Survival, Skyblock, Factions, SMP & more. Find your next multiplayer home."
  url="https://guildpost.tech"
  keywords="minecraft servers, server list, minecraft multiplayer, game servers, pvp servers, survival servers, skyblock, factions, smp, rust servers, cs2 servers"
>
  <div class="min-h-screen bg-[#0a0a0f]">
    <Header />

    <!-- Hero Section -->
    <section class="px-4 py-20 md:py-32">
      <div class="max-w-6xl mx-auto text-center">
        <h1 class="text-5xl md:text-7xl font-black mb-6">
          <span class="text-white">Find Your</span>
          <br />
          <span class="text-[#ff3864]">SERVER</span>
        </h1>
        <p class="text-[#8892b0] text-xl md:text-2xl max-w-2xl mx-auto mb-12">
          The ultimate directory for game servers. 
          From Minecraft to Rust, discover your next multiplayer home.
        </p>

        <!-- Animated Stats -->
        <div 
          class="flex justify-center gap-8 md:gap-16 mb-8 py-6 px-8 bg-[#12121a] border border-[#2a2a3a] max-w-2xl mx-auto"
          style="clip-path: polygon(5% 0, 100% 0, 95% 100%, 0 100%)"
        >
          <AnimatedStat value={1037} label="Servers" color="#00f5d4" />
          <AnimatedStat value={50} suffix="+" label="Game Modes" color="#00f5d4" />
          <AnimatedStat value={0} label="Fake Reviews" color="#ff3864" />
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/minecraft"
            class="inline-flex items-center gap-2 bg-[#00f5d4] text-[#0a0a0f] px-8 py-4 font-bold text-lg hover:bg-[#00d4b8] transition-colors"
            style="clip-path: polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0 30%)"
          >
            Browse Minecraft
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/submit"
            class="inline-flex items-center gap-2 border-2 border-[#2a2a3a] text-white px-8 py-4 font-bold text-lg hover:border-[#00f5d4] hover:text-[#00f5d4] transition-colors"
            style="clip-path: polygon(0 0, 90% 0, 100% 30%, 100% 100%, 10% 100%, 0 70%)"
          >
            Add Your Server
          </a>
        </div>
      </div>
    </section>

    <!-- Game Categories -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-8 text-center">
          Browse by Game
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {gameCategories.map((game) => (
            <a
              href={game.href}
              class={`group p-8 border-2 transition-all ${
                game.featured
                  ? "border-[#00f5d4] bg-[#00f5d4]/5 hover:bg-[#00f5d4]/10"
                  : "border-[#2a2a3a] opacity-60 hover:opacity-100 hover:border-[#3a3a4a]"
              }`}
              style="clip-path: polygon(5% 0, 100% 0, 100% 95%, 95% 100%, 0 100%, 0 5%)"
            >
              <div class="mb-4" style={`color: ${game.iconColor}`}>
                {game.id === 'minecraft' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                )}
                {game.id === 'rust' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                )}
                {game.id === 'cs2' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 17.5 3 6V3h3l11.5 11.5"/><path d="m13 19 6-6"/><path d="m16 16 4 4"/><path d="m19 21 2-2"/></svg>
                )}
              </div>
              <h3 class="text-2xl font-bold text-white mb-2">
                {game.name}
              </h3>
              <p class="text-[#8892b0] mb-4">
                {game.description}
              </p>
              {game.serverCount > 0 && (
                <p class="text-[#00f5d4] font-bold">
                  {game.serverCount.toLocaleString()} servers
                </p>
              )}
              {game.featured && (
                <div class="mt-4 flex items-center gap-2 text-[#00f5d4]">
                  <span class="text-sm font-medium">Explore</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Search Bar Section -->
    <section class="px-4 py-8 border-t border-[#1a1a25]">
      <div class="max-w-4xl mx-auto">
        <form action="/search" method="GET" class="flex gap-2">
          <div class="flex-1 relative">
            <input 
              type="search" 
              name="q"
              placeholder="Search servers by name, IP, or game mode..."
              class="w-full px-4 py-4 pl-12 bg-[#12121a] border border-[#2a2a3a] text-white placeholder-[#8892b0] rounded-lg focus:outline-none focus:border-[#00f5d4] transition-colors text-lg"
            />
            <svg 
              class="absolute left-4 top-1/2 -translate-y-1/2 text-[#8892b0]" 
              xmlns="http://www.w3.org/2000/svg" 
              width="20" 
              height="20" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              stroke-width="2"
            >
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
          </div>
          <button 
            type="submit"
            class="px-8 py-4 bg-[#00f5d4] text-[#0a0a0f] font-bold hover:bg-[#00d4b8] transition-colors rounded-lg"
          >
            Search
          </button>
        </form>
        
        <!-- Quick Search Tags -->
        <div class="mt-4 flex flex-wrap gap-2 justify-center">
          <span class="text-sm text-[#8892b0]">Popular:</span>
          {['PvP', 'Survival', 'Skyblock', 'Factions', 'SMP', 'Minigames', 'Prison', 'Bedwars'].map(tag => (
            <a href={`/search?q=${tag.toLowerCase()}`} class="text-sm text-[#00f5d4] hover:underline">
              {tag}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Trending Servers (Most Voted Today) -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-3">
            <h2 class="text-3xl font-bold text-white">
              🔥 Trending Today
            </h2>
            <span class="px-3 py-1 bg-[#ff3864]/20 text-[#ff3864] text-sm font-bold rounded-full">
              HOT
            </span>
          </div>
          <a href="/search?sort=votes" class="text-[#00f5d4] hover:underline flex items-center gap-2">
            View All
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        
        <div id="trending-servers" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          <div class="col-span-full text-center py-12 text-[#8892b0]">
            Loading trending servers...
          </div>
        </div>
      </div>
    </section>

    <!-- Recently Added Servers -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-3">
            <h2 class="text-3xl font-bold text-white">
              ✨ New Servers
            </h2>
            <span class="px-3 py-1 bg-[#00f5d4]/20 text-[#00f5d4] text-sm font-bold rounded-full">
              JUST ADDED
            </span>
          </div>
          <a href="/search?sort=recent" class="text-[#00f5d4] hover:underline flex items-center gap-2">
            View All
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        
        <div id="recent-servers" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          <div class="col-span-full text-center py-12 text-[#8892b0]">
            Loading new servers...
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Minecraft Servers -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-white">
            ⭐ Top Rated Servers
          </h2>
          <a href="/minecraft" class="text-[#00f5d4] hover:underline flex items-center gap-2">
            View All
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div id="featured-servers" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          <div class="col-span-full text-center py-12 text-[#8892b0]">
            Loading servers...
          </div>
        </div>
      </div>
    </section>

    <!-- Why GuildPost -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-12 text-center">
          Why GuildPost?
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-[#12121a] border border-[#2a2a3a] flex items-center justify-center mx-auto mb-4 text-2xl">
              🎮
            </div>
            <h3 class="text-xl font-bold text-white mb-2">
              Multi-Game Support
            </h3>
            <p class="text-[#8892b0]">
              Starting with Minecraft, expanding to Rust, CS2, and more.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-[#12121a] border border-[#2a2a3a] flex items-center justify-center mx-auto mb-4 text-2xl">
              👥
            </div>
            <h3 class="text-xl font-bold text-white mb-2">
              Community Driven
            </h3>
            <p class="text-[#8892b0]">
              Real player votes and reviews. No pay-to-win placement.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-[#12121a] border border-[#2a2a3a] flex items-center justify-center mx-auto mb-4 text-2xl">
              📊
            </div>
            <h3 class="text-xl font-bold text-white mb-2">
              Live Status
            </h3>
            <p class="text-[#8892b0]">
              Real-time player counts and latency. Know before you join.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer CTA -->
    <section class="px-4 py-16 border-t border-[#1a1a25]">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          Ready to Find Your Server?
        </h2>
        <p class="text-[#8892b0] mb-8">
          Join thousands of players discovering their next favorite server.
        </p>
        <a
          href="/minecraft"
          class="inline-flex items-center gap-2 bg-[#ff3864] text-white px-8 py-4 font-bold text-lg hover:bg-[#e63357] transition-colors"
          style="clip-path: polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0 30%)"
        >
          Start Browsing
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-4 py-8 border-t border-[#2a2a3a]">
      <div class="max-w-6xl mx-auto text-center text-[#8892b0]">
        <p>
          Built for the community. Not for profit. 
          <a href="https://github.com/mintychochip/guildpost" class="text-[#00f5d4] hover:underline ml-2">
            Open source
          </a>
        </p>
      </div>
    </footer>
  </div>
</Layout>

<!-- Client-side script to fetch servers -->
<script>
  import { createClient } from '@supabase/supabase-js';
  
  const supabaseUrl = 'https://wpxutsdbiampnxfgkjwq.supabase.co';
  const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndweHV0c2RiaWFtcG54ZmdrandxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNTEwMDQsImV4cCI6MjA5MDkyNzAwNH0.FUiWKe-SwTnKEQFmVzN4L46E5gP2qXl1MnEkrzjWfSw';
  
  // Log for debugging
  console.log('Supabase URL:', supabaseUrl);
  console.log('Loading servers...');
  
  function renderServerCard(server) {
    const isOnline = server.status === 'online';
    return `
      <a href="/servers/${server.id}" class="block p-5 bg-[#12121a] border border-[#2a2a3a] hover:border-[#00f5d4] transition-colors group rounded-lg">
        <div class="flex items-start gap-4 mb-4">
          ${server.icon ? `
            <div class="relative">
              <img src="${server.icon}" alt="" class="w-14 h-14 rounded bg-[#1a1a25]" loading="lazy" />
              <span class="absolute -bottom-1 -right-1 w-4 h-4 rounded-full ${isOnline ? 'bg-green-500' : 'bg-red-500'} border-2 border-[#12121a]"></span>
            </div>
          ` : `
            <div class="relative">
              <div class="w-14 h-14 rounded bg-[#1a1a25] flex items-center justify-center">
                <span class="text-[#00f5d4] text-2xl">⛏</span>
              </div>
              <span class="absolute -bottom-1 -right-1 w-4 h-4 rounded-full ${isOnline ? 'bg-green-500' : 'bg-red-500'} border-2 border-[#12121a]"></span>
            </div>
          `}
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-bold text-white group-hover:text-[#00f5d4] transition-colors truncate text-lg">${server.name}</h3>
              ${isOnline ? `<span class="px-2 py-0.5 bg-green-500/20 text-green-500 text-xs font-bold rounded">ONLINE</span>` : ''}
            </div>
            <p class="text-sm text-[#8892b0] font-mono truncate">${server.ip}:${server.port}</p>
          </div>
        </div>
        <div class="flex items-center gap-4 mb-3 text-sm">
          <span class="flex items-center gap-1 ${isOnline ? 'text-green-500' : 'text-[#8892b0]'}">
            <span class="w-1.5 h-1.5 rounded-full ${isOnline ? 'bg-green-500' : 'bg-gray-500'}"></span>
            ${isOnline ? `${server.players_online || 0}/${server.max_players || 0}` : 'Offline'}
          </span>
          <span class="flex items-center gap-1 text-[#ff3864]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 15-6-6-6 6"/></svg>
            ${server.vote_count || 0}
          </span>
        </div>
        <div class="flex flex-wrap gap-1">
          ${(server.tags || []).slice(0, 3).map(tag => `<span class="text-xs px-2 py-1 bg-[#1a1a25] text-[#8892b0] rounded">${tag}</span>`).join('')}
          ${server.version ? `<span class="text-xs px-2 py-1 bg-[#00f5d4]/10 text-[#00f5d4] rounded">${server.version}</span>` : ''}
        </div>
      </a>
    `;
  }

  async function loadServers() {
    try {
      const supabase = createClient(supabaseUrl, supabaseKey);
      
      // Load trending (most voted)
      const { data: trending, error: trendingError } = await supabase
        .from('servers')
        .select('id, ip, port, name, description, version, tags, verified, vote_count, icon, banner, status, players_online, max_players')
        .order('vote_count', { ascending: false })
        .limit(6);
      
      if (trendingError) {
        console.error('Trending error:', trendingError);
        document.getElementById('trending-servers').innerHTML = `<div class="col-span-full text-center py-12 text-[#ff3864]">Error: ${trendingError.message}</div>`;
      } else if (trending && trending.length > 0) {
        document.getElementById('trending-servers').innerHTML = trending.map(renderServerCard).join('');
      } else {
        document.getElementById('trending-servers').innerHTML = '<div class="col-span-full text-center py-12 text-[#8892b0]">No servers yet</div>';
      }
      
      // Load recently added
      const { data: recent, error: recentError } = await supabase
        .from('servers')
        .select('id, ip, port, name, description, version, tags, verified, vote_count, icon, banner, status, players_online, max_players, created_at')
        .order('created_at', { ascending: false })
        .limit(6);
      
      if (recentError) {
        console.error('Recent error:', recentError);
        document.getElementById('recent-servers').innerHTML = `<div class="col-span-full text-center py-12 text-[#ff3864]">Error: ${recentError.message}</div>`;
      } else if (recent && recent.length > 0) {
        document.getElementById('recent-servers').innerHTML = recent.map(renderServerCard).join('');
      } else {
        document.getElementById('recent-servers').innerHTML = '<div class="col-span-full text-center py-12 text-[#8892b0]">No servers yet</div>';
      }
      
      // Load featured (top rated)
      const { data: featured, error: featuredError } = await supabase
        .from('servers')
        .select('id, ip, port, name, description, version, tags, verified, vote_count, icon, banner, status, players_online, max_players')
        .order('vote_count', { ascending: false })
        .limit(6);
      
      if (featuredError) {
        console.error('Featured error:', featuredError);
        document.getElementById('featured-servers').innerHTML = `<div class="col-span-full text-center py-12 text-[#ff3864]">Error loading servers: ${featuredError.message}</div>`;
        return;
      }
      
      if (featured && featured.length > 0) {
        document.getElementById('featured-servers').innerHTML = featured.map(renderServerCard).join('');
      } else {
        document.getElementById('featured-servers').innerHTML = '<div class="col-span-full text-center py-12 text-[#8892b0]">No servers found. <a href="/submit" class="text-[#00f5d4] hover:underline">Add the first one!</a></div>';
      }
    } catch (err) {
      console.error('Load servers error:', err);
      document.getElementById('trending-servers').innerHTML = `<div class="col-span-full text-center py-12 text-[#ff3864]">Failed to connect to database</div>`;
      document.getElementById('recent-servers').innerHTML = `<div class="col-span-full text-center py-12 text-[#ff3864]">Failed to connect to database</div>`;
      document.getElementById('featured-servers').innerHTML = `<div class="col-span-full text-center py-12 text-[#ff3864]">Failed to connect to database. Check console for details.</div>`;
    }
  }
  
  // Load servers when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadServers);
  } else {
    loadServers();
  }
</script>