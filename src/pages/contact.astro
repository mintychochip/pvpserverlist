---
// Contact Support Page
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const contactReasons = [
  { value: 'general', label: 'General Question' },
  { value: 'server-issue', label: 'Server Listing Issue' },
  { value: 'billing', label: 'Billing / Premium' },
  { value: 'report', label: 'Report Server / User' },
  { value: 'bug', label: 'Bug Report' },
  { value: 'feature', label: 'Feature Request' },
  { value: 'partnership', label: 'Partnership Inquiry' },
];

const responseTime = "We typically respond within 24-48 hours. For faster help, join our Discord!";
---

<Layout 
  title="Contact Us - GuildPost Support"
  description="Get help with GuildPost. Contact our support team for questions about server discovery, billing, bug reports, or partnership inquiries."
  url="https://guildpost.tech/contact"
>
  <div class="min-h-screen" style="background-color: var(--bg-primary);">
    <Header />
    
    <main class="pt-20 pb-16">
      <div class="max-w-4xl mx-auto px-4">
        <!-- Header -->
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-black text-white mb-4">
            Contact Support 🎫
          </h1>
          <p class="text-[#8892b0] text-lg max-w-2xl mx-auto">
            Need help? We're here for you. Fill out the form below and we'll get back to you as soon as possible.
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Contact Form -->
          <div class="md:col-span-2">
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-xl">
              <form id="contact-form" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label class="text-[#8892b0] text-sm block mb-2">Name *</label>
                    <input 
                      type="text" 
                      name="name" 
                      required
                      class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4]"
                      placeholder="Your name"
                    />
                  </div>
                  <div>
                    <label class="text-[#8892b0] text-sm block mb-2">Email *</label>
                    <input 
                      type="email" 
                      name="email" 
                      required
                      class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4]"
                      placeholder="your@email.com"
                    />
                  </div>
                </div>
                
                <div>
                  <label class="text-[#8892b0] text-sm block mb-2">Reason for Contact *</label>
                  <select 
                    name="reason" 
                    required
                    class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white focus:outline-none focus:border-[#00f5d4]"
                  >
                    <option value="">Select a reason...</option>
                    {contactReasons.map(r => (
                      <option value={r.value}>{r.label}</option>
                    ))}
                  </select>
                </div>
                
                <div>
                  <label class="text-[#8892b0] text-sm block mb-2">Subject *</label>
                  <input 
                    type="text" 
                    name="subject" 
                    required
                    class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4]"
                    placeholder="Brief summary of your issue"
                  />
                </div>
                
                <div>
                  <label class="text-[#8892b0] text-sm block mb-2">Message *</label>
                  <textarea 
                    name="message" 
                    rows="5" 
                    required
                    class="w-full px-4 py-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8892b0] focus:outline-none focus:border-[#00f5d4] resize-none"
                    placeholder="Describe your issue or question in detail..."
                  ></textarea>
                </div>
                
                <div class="flex items-start gap-3">
                  <input 
                    type="checkbox" 
                    id="discord-user" 
                    name="is_discord_user"
                    class="mt-1 w-4 h-4 accent-[#00f5d4]"
                  />
                  <label for="discord-user" class="text-[#8892b0] text-sm">
                    I am a Discord user and would prefer to be contacted via Discord
                  </label>
                </div>
                
                <button 
                  type="submit"
                  id="submit-btn"
                  class="w-full py-4 bg-[#00f5d4] hover:bg-[#00d4b8] text-[#0a0a0f] font-bold rounded-lg transition-colors flex items-center justify-center gap-2"
                >
                  <span id="btn-text">Send Message</span>
                  <svg id="btn-spinner" class="animate-spin hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
                </button>
                
                <p id="form-message" class="text-center text-sm hidden"></p>
              </form>
              
              <p class="text-[#8892b0] text-xs mt-4 text-center">
                {responseTime}
              </p>
            </div>
          </div>
          
          <!-- Contact Info Sidebar -->
          <div class="space-y-4">
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-xl">
              <h3 class="font-bold text-white mb-4 flex items-center gap-2">
                <span>💬</span> Quick Support
              </h3>
              <div class="space-y-3">
                <a href="https://discord.gg/clawd" target="_blank" class="flex items-center gap-3 p-3 bg-[#5865F2]/20 border border-[#5865F2]/30 rounded-lg hover:bg-[#5865F2]/30 transition-colors">
                  <svg class="w-6 h-6 text-[#5865F2]" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                  </svg>
                  <div>
                    <p class="text-white font-medium">Discord Server</p>
                    <p class="text-[#8892b0] text-xs">Fastest response</p>
                  </div>
                </a>
                
                <a href="mailto:support@guildpost.tech" class="flex items-center gap-3 p-3 bg-[#0a0a0f] border border-[#2a2a3a] rounded-lg hover:border-[#00f5d4] transition-colors">
                  <svg class="w-6 h-6 text-[#00f5d4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                  <div>
                    <p class="text-white font-medium">Email Support</p>
                    <p class="text-[#8892b0] text-xs">support@guildpost.tech</p>
                  </div>
                </a>
              </div>
            </div>
            
            <div class="p-6 bg-[#12121a] border border-[#2a2a3a] rounded-xl">
              <h3 class="font-bold text-white mb-4">📚 Help Resources</h3>
              <ul class="space-y-2 text-sm">
                <li>
                  <a href="/help" class="text-[#8892b0] hover:text-[#00f5d4] transition-colors flex items-center gap-2">
                    <span>→</span> Help Center
                  </a>
                </li>
                <li>
                  <a href="/status" class="text-[#8892b0] hover:text-[#00f5d4] transition-colors flex items-center gap-2">
                    <span>→</span> System Status
                  </a>
                </li>
                <li>
                  <a href="/terms" class="text-[#8892b0] hover:text-[#00f5d4] transition-colors flex items-center gap-2">
                    <span>→</span> Terms of Service
                  </a>
                </li>
                <li>
                  <a href="/privacy" class="text-[#8892b0] hover:text-[#00f5d4] transition-colors flex items-center gap-2">
                    <span>→</span> Privacy Policy
                  </a>
                </li>
              </ul>
            </div>
            
            <div class="p-6 bg-gradient-to-br from-[#00f5d4]/10 to-[#a855f7]/10 border border-[#2a2a3a] rounded-xl">
              <h3 class="font-bold text-white mb-2">⚡ Priority Support</h3>
              <p class="text-[#8892b0] text-sm mb-3">
                Premium and Elite members get priority support with faster response times.
              </p>
              <a href="/premium" class="text-[#00f5d4] hover:underline text-sm font-medium">
                View Premium Plans →
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
    
    <Footer />
  </div>
  
  <script>
    // Simple form handler (would connect to backend/Discord webhook in production)
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnSpinner = document.getElementById('btn-spinner');
    const formMessage = document.getElementById('form-message');
    
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Show loading
      submitBtn.disabled = true;
      btnText.textContent = 'Sending...';
      btnSpinner.classList.remove('hidden');
      
      // Simulate submission (in production, send to API)
      await new Promise(r => setTimeout(r, 1500));
      
      // Show success
      formMessage.textContent = '✅ Message sent! We\'ll get back to you soon.';
      formMessage.className = 'text-center text-sm text-green-500 mt-4';
      formMessage.classList.remove('hidden');
      
      // Reset
      form.reset();
      submitBtn.disabled = false;
      btnText.textContent = 'Send Message';
      btnSpinner.classList.add('hidden');
      
      // Hide message after 5s
      setTimeout(() => {
        formMessage.classList.add('hidden');
      }, 5000);
    });
  </script>
</Layout>