{
  "name": "guildpost-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && cp public/_routes.json dist/_routes.json && cp public/_routes.json _routes.json",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run --passWithNoTests",
    "deploy": "wrangler pages deploy dist",
    "test:watch": "vitest",
    "i18n:init": "crowdin init",
    "i18n:upload": "crowdin upload sources",
    "i18n:download": "crowdin download",
    "i18n:sync": "npm run i18n:upload && npm run i18n:download",
    "i18n:status": "crowdin status",
    "discord:register": "node scripts/register-discord-commands.mjs",
    "discord:unregister": "node scripts/register-discord-commands.mjs --delete"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.0",
    "@supabase/supabase-js": "^2.105.1",
    "astro": "^6.2.1",
    "chart.js": "^4.5.1",
    "crypto-js": "^4.2.0",
    "minecraft-server-util": "^5.4.4",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@crowdin/cli": "^4.14.2",
    "pm2": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "vitest": "^3.2.4"
  }
}
